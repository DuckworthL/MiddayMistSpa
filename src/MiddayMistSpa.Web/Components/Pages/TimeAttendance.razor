        public string Initials { get; set; } = string.Empty;
        public bool IsClockedIn { get; set; }
        public DateTime? ClockIn { get; set; }
        public DateTime? ClockOut { get; set; }
        public bool OnBreak { get; set; }
        public DateTime? BreakStart { get; set; }
        /// <summary>NotYetIn | ClockedIn | OnBreak | ClockedOut</summary>
        public string Status { get; set; } = "NotYetIn";
    }

    private class TimesheetViewModel
    {
        public int EmployeeId { get; set; }
        public string EmployeeName { get; set; } = string.Empty;
        public string Initials { get; set; } = string.Empty;
        public string Position { get; set; } = string.Empty;
        public decimal[] DailyHours { get; set; } = new decimal[7];
        public decimal TotalHours => DailyHours.Sum();
        public decimal OvertimeHours => Math.Max(0, TotalHours - 40);
    }

    private class TimeEntryViewModel
    {
        public int EmployeeId { get; set; }
        public string EmployeeName { get; set; } = string.Empty;
        public DateTime Date { get; set; }
        public TimeSpan ClockIn { get; set; }
        public TimeSpan? ClockOut { get; set; }
        public int BreakMinutes { get; set; }
        public bool IsApproved { get; set; }
        public decimal TotalHours => ClockOut.HasValue
        ? (decimal)(ClockOut.Value - ClockIn - TimeSpan.FromMinutes(BreakMinutes)).TotalHours
        : (decimal)(DateTime.Now.TimeOfDay - ClockIn - TimeSpan.FromMinutes(BreakMinutes)).TotalHours;
    }

