@page "/reset-password"
@layout EmptyLayout
@inject NavigationManager Navigation
@inject IApiClient ApiClient

<PageTitle>Reset Password - MiddayMist Spa</PageTitle>

<div class="forgot-password-page">
    <div class="forgot-password-container">
        <div class="forgot-password-card">
            @if (!_resetSuccess)
            {
                <div class="card-icon">
                    <i class="bi bi-shield-lock"></i>
                </div>
                <h2 class="card-title">Reset Password</h2>
                <p class="card-subtitle">Enter your reset code and new password below.</p>

                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <div class="alert alert-danger d-flex align-items-center" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        <div>@_errorMessage</div>
                    </div>
                }

                <EditForm Model="_model" OnValidSubmit="HandleReset" FormName="resetPassword">
                    <DataAnnotationsValidator />

                    <div class="form-floating mb-3">
                        <InputText @bind-Value="_model.Email" class="form-control" id="email"
                            placeholder="name@example.com" />
                        <label for="email"><i class="bi bi-envelope me-2"></i>Email Address</label>
                        <ValidationMessage For="@(() => _model.Email)" />
                    </div>

                    <div class="form-floating mb-3">
                        <InputText @bind-Value="_model.Token" class="form-control" id="token"
                            placeholder="000000" />
                        <label for="token"><i class="bi bi-key me-2"></i>Reset Code</label>
                        <ValidationMessage For="@(() => _model.Token)" />
                    </div>

                    <div class="form-floating mb-3">
                        <InputText @bind-Value="_model.NewPassword" type="password" class="form-control" id="newPassword"
                            placeholder="New Password" />
                        <label for="newPassword"><i class="bi bi-lock me-2"></i>New Password</label>
                        <ValidationMessage For="@(() => _model.NewPassword)" />
                    </div>

                    <div class="form-floating mb-3">
                        <InputText @bind-Value="_model.ConfirmPassword" type="password" class="form-control" id="confirmPassword"
                            placeholder="Confirm Password" />
                        <label for="confirmPassword"><i class="bi bi-lock-fill me-2"></i>Confirm Password</label>
                        <ValidationMessage For="@(() => _model.ConfirmPassword)" />
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-3" disabled="@_isLoading">
                        @if (_isLoading)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                            <span>Resetting...</span>
                        }
                        else
                        {
                            <i class="bi bi-check-lg me-2"></i>
                            <span>Reset Password</span>
                        }
                    </button>
                </EditForm>
            }
            else
            {
                <div class="card-icon success">
                    <i class="bi bi-check-circle"></i>
                </div>
                <h2 class="card-title">Password Reset!</h2>
                <p class="card-subtitle">Your password has been reset successfully. You can now sign in with your new password.</p>

                <button class="btn btn-primary w-100 py-3" @onclick="GoToLogin">
                    <i class="bi bi-box-arrow-in-right me-2"></i>
                    Sign In
                </button>
            }

            <div class="back-to-login mt-4">
                <a href="/login" class="text-muted">
                    <i class="bi bi-arrow-left me-1"></i> Back to Login
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    .forgot-password-page {
        min-height: 100vh;
        background: linear-gradient(135deg, #F8FAF8 0%, #E8EFE8 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem;
    }
    .forgot-password-container { width: 100%; max-width: 450px; }
    .forgot-password-card {
        background: white;
        border-radius: 1.5rem;
        padding: 2.5rem;
        border: 1px solid #E5E7EB;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.06);
        text-align: center;
    }
    .card-icon {
        width: 80px; height: 80px;
        background: linear-gradient(135deg, #3D5A4F 0%, #2A3F36 100%);
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        margin: 0 auto 1.5rem;
        font-size: 2rem; color: white;
    }
    .card-icon.success { background: linear-gradient(135deg, #059669 0%, #047857 100%); }
    .card-title { font-size: 1.75rem; font-weight: 700; color: #2C2C2C; margin-bottom: 0.75rem; }
    .card-subtitle { color: #6B7280; margin-bottom: 2rem; font-size: 0.9375rem; line-height: 1.5; }
    .form-floating > .form-control { padding-left: 1rem; height: 3.5rem; }
    .form-floating > label { padding-left: 1rem; }
    .btn-primary { background: linear-gradient(135deg, #3D5A4F 0%, #2A3F36 100%); border: none; font-weight: 600; }
    .btn-primary:hover { background: linear-gradient(135deg, #2A3F36 0%, #1F2E28 100%); }
    .back-to-login a { text-decoration: none; font-size: 0.875rem; }
    .back-to-login a:hover { color: #3D5A4F !important; }
</style>

@code {
    private ResetPasswordModel _model = new();
    private bool _isLoading;
    private bool _resetSuccess;
    private string? _errorMessage;

    protected override void OnInitialized()
    {
        var uri = new Uri(Navigation.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        var email = query["email"];
        if (!string.IsNullOrEmpty(email))
            _model.Email = email;
    }

    private async Task HandleReset()
    {
        _isLoading = true;
        _errorMessage = null;

        if (_model.NewPassword != _model.ConfirmPassword)
        {
            _errorMessage = "Passwords do not match";
            _isLoading = false;
            return;
        }

        try
        {
            var result = await ApiClient.PostAsync<object, PasswordResetResponse>(
                "api/auth/reset-password",
                new
                {
                    Email = _model.Email,
                    Token = _model.Token,
                    NewPassword = _model.NewPassword,
                    ConfirmPassword = _model.ConfirmPassword
                });

            if (result?.Success == true)
            {
                _resetSuccess = true;
            }
            else
            {
                _errorMessage = result?.Message ?? "Failed to reset password. Please check your code and try again.";
            }
        }
        catch (Exception)
        {
            _errorMessage = "An error occurred. Please try again later.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void GoToLogin()
    {
        Navigation.NavigateTo("/login");
    }

    public class ResetPasswordModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Email is required")]
        [System.ComponentModel.DataAnnotations.EmailAddress(ErrorMessage = "Please enter a valid email address")]
        public string Email { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Reset code is required")]
        public string Token { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "New password is required")]
        [System.ComponentModel.DataAnnotations.MinLength(8, ErrorMessage = "Password must be at least 8 characters")]
        public string NewPassword { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Please confirm your password")]
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}
