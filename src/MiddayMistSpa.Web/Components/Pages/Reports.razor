    private async Task GenerateReport(string reportId)
    {
        if (reportId == "custom")
        {
            var (startDate, endDate) = GetDateRange();
            _customReportStart = startDate;
            _customReportEnd = endDate;
            _showCustomReportModal = true;
            return;
        }

        _exportReportType = reportId switch
        {
            "revenue" => "sales",
            "appointments" => "appointment",
            "customers" => "customer",
            "inventory" => "inventory",
            "payroll" => "payroll",
            "services" => "sales",
            "marketing" => "sales",
            _ => "financial"
        };
        await ExportReport();
    }

    private async Task GenerateCustomReport()
    {
        _showCustomReportModal = false;
        _isExporting = true;
        StateHasChanged();
        try
        {
            var (fileContent, fileName, contentType, errorMessage) = await ReportsService.ExportReportAsync(
                _customReportType, _customReportFormat, _customReportStart, _customReportEnd);

            if (fileContent != null && fileName != null)
            {
                var base64 = Convert.ToBase64String(fileContent);
                await JSRuntime.InvokeVoidAsync("downloadFile", fileName, contentType ?? "application/octet-stream", base64);
                ShowAlert($"{_customReportType} report exported successfully!", Alert.AlertType.Success);
            }
            else
            {
                ShowAlert(errorMessage ?? "Export failed. Please try again.", Alert.AlertType.Error);
            }
        }
        catch (Exception ex)
        {
            ShowAlert($"Export failed: {ex.Message}", Alert.AlertType.Error);
        }
        finally
        {
            _isExporting = false;
            StateHasChanged();
        }
    }

    private async Task ExportReport()
    {
        _isExporting = true;
        StateHasChanged();
        try
        {
            var (startDate, endDate) = GetDateRange();
            var reportType = _exportReportType ?? "sales";

            var (fileContent, fileName, contentType, errorMessage) = await ReportsService.ExportReportAsync(reportType, _exportFormat, startDate, endDate);

            if (fileContent != null && fileName != null)
            {
                var base64 = Convert.ToBase64String(fileContent);
                await JSRuntime.InvokeVoidAsync("downloadFile", fileName, contentType ?? "application/octet-stream", base64);
                ShowAlert($"{reportType} report exported successfully!", Alert.AlertType.Success);
            }
            else
            {
                ShowAlert(errorMessage ?? "Export failed. Please try again.", Alert.AlertType.Error);
            }
        }
        catch (Exception ex)
        {
            ShowAlert($"Export failed: {ex.Message}", Alert.AlertType.Error);
        }
        finally
        {
            _isExporting = false;
            _exportReportType = "sales";
            StateHasChanged();
        }
    }

    private void ShowAlert(string message, Alert.AlertType type)
    {
        _alertMessage = message;
        _alertType = type;
    }

