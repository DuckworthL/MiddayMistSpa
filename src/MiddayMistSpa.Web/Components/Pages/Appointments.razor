    private void ShowAlert(string message, Alert.AlertType type)
    {
        _alertMessage = message;
        _alertType = type;
    }

    private string GetRowClass(AppointmentResponse appt) => appt.Status switch
    {
        "Completed" => "table-success",
        "Cancelled" or "No Show" => "table-secondary text-muted",
        "Checked In" => "table-warning",
        "In Progress" => "table-info",
        _ => ""
    };

    private string GetAppointmentClass(AppointmentResponse appt) => appt.Status switch
    {
        "Completed" => "bg-success text-white",
        "Cancelled" or "No Show" => "bg-secondary text-white opacity-50",
        "Checked In" => "bg-warning text-dark",
        "In Progress" => "bg-info text-white",
        "Confirmed" => "bg-primary text-white",
        _ => "bg-primary bg-opacity-75 text-white"
    };

    // ========================================================================
    // Appointment Progress Methods
    // ========================================================================

    private async Task StartAppointment(AppointmentResponse appt)
    {
        try
        {
            // First check-in if needed (Scheduled/Confirmed → Checked-In)
            if (appt.Status is "Scheduled" or "Confirmed")
            {
                var checkedIn = await AppointmentService.CheckInAppointmentAsync(appt.AppointmentId);
                if (checkedIn == null)
                {
                    ShowAlert("Failed to check in appointment.", Alert.AlertType.Error);
                    return;
                }
            }

            // Then start service (Checked-In → In Progress)
            var result = await AppointmentService.StartServiceAsync(appt.AppointmentId);

            if (result != null)
            {
                // Create a Pending transaction so it shows up in the Transactions list
                try
                {
                    _pendingTransaction = await TransactionService.CreatePendingTransactionAsync(appt.AppointmentId);
                }
                catch (Exception ex)
                {
                    // Non-critical — log but don't block the service start
                    Console.WriteLine($"Warning: Could not create pending transaction: {ex.Message}");
                }

                ShowAlert("Service started!", Alert.AlertType.Success);
                await LoadAppointments();

                // Open progress modal with the full appointment data from the start response
                await OpenProgressModal(result);
            }
            else
            {
                ShowAlert("Failed to start service.", Alert.AlertType.Error);
            }
        }
        catch (Exception ex)
        {
            ShowAlert($"Error starting service: {ex.Message}", Alert.AlertType.Error);
        }
    }

    private async Task OpenProgressModal(AppointmentResponse appt)
    {
        // Fetch full appointment details by ID to get all fields (ServiceId, DurationMinutes, CustomerId, etc.)
        // The list endpoint returns AppointmentListResponse which is missing these fields
        var fullAppt = await AppointmentService.GetAppointmentByIdAsync(appt.AppointmentId);
        _activeAppointment = fullAppt ?? appt;

        // ServiceStartedAt is stored in UTC — convert to PHT for display and elapsed calculation
        _serviceStartTime = _activeAppointment.ServiceStartedAt.HasValue
        ? PhilippineTime.FromUtc(_activeAppointment.ServiceStartedAt.Value)
        : PhilippineTime.Now.Date.Add(_activeAppointment.StartTime);
        _checkoutProducts = new();
        _selectedProductId = 0;
        _paymentMethod = "Cash";
        _showProductSection = false;

        // Get service price using the correct ServiceId from full appointment data
        _servicePrice = 0;
        if (_activeAppointment.ServiceId > 0)
        {
            var services = await ServiceApiService.GetServicesAsync();
            var service = services.Items.FirstOrDefault(s => s.ServiceId == _activeAppointment.ServiceId);
            _servicePrice = service?.RegularPrice ?? 0;
        }

        // Also use ServicePrice from the appointment if available and price lookup failed
        if (_servicePrice == 0 && _activeAppointment.ServicePrice > 0)
        {
            _servicePrice = _activeAppointment.ServicePrice;
        }

        // Load products for add-ons
        _productLookup = await InventoryService.GetProductLookupAsync();

        // Try to find an existing pending transaction for this appointment
        if (_pendingTransaction == null)
        {
            try
            {
                _pendingTransaction = await
                TransactionService.GetPendingTransactionByAppointmentAsync(_activeAppointment.AppointmentId);
            }
            catch { /* non-critical */ }
        }

        // Start the timer
        StartTimer();

        _showProgressModal = true;
    }

    private void StartTimer()
    {
        _timer?.Dispose();
        _timer = new System.Threading.Timer(UpdateTimer, null, 0, 1000);
    }

    private void UpdateTimer(object? state)
    {
        if (_serviceStartTime.HasValue && _activeAppointment != null)
        {
            _elapsedTime = PhilippineTime.Now - _serviceStartTime.Value;
            _progressPercent = (_elapsedTime.TotalMinutes / _activeAppointment.TotalDurationMinutes) * 100;

            InvokeAsync(StateHasChanged);
        }
    }

    private void CloseProgressModal()
    {
        _timer?.Dispose();
        _timer = null;
        _showProgressModal = false;
        _activeAppointment = null;
    }

    private void ToggleProductSection()
    {
        _showProductSection = !_showProductSection;
    }

    private void AddProductToCheckout()
    {
        if (_selectedProductId == 0) return;

        var product = _productLookup.FirstOrDefault(p => p.Id == _selectedProductId);
        if (product == null) return;

        var existing = _checkoutProducts.FirstOrDefault(p => p.ProductId == _selectedProductId);
        if (existing != null)
        {
            existing.Quantity++;
        }
        else
        {
            _checkoutProducts.Add(new CheckoutProduct
            {
                ProductId = product.Id,
                Name = product.Name,
                Price = product.Price ?? 0,
                Quantity = 1
            });
        }

        _selectedProductId = 0;
    }

    private void RemoveProduct(CheckoutProduct product)
    {
        _checkoutProducts.Remove(product);
    }

    private async Task AddServiceToAppointment()
    {
        if (_activeAppointment == null || _addServiceId == 0) return;

        _isAddingService = true;
        try
        {
            var request = new AddServiceToAppointmentRequest { ServiceId = _addServiceId, Quantity = 1 };
            var updated = await AppointmentService.AddServiceToAppointmentAsync(_activeAppointment.AppointmentId, request);
            if (updated != null)
            {
                _activeAppointment = updated;
                _servicePrice = updated.TotalPrice;
                ShowAlert("Service added to appointment!", Alert.AlertType.Success);
            }
            else
            {
                ShowAlert("Failed to add service.", Alert.AlertType.Error);
            }
        }
        catch (Exception ex)
        {
            ShowAlert($"Error adding service: {ex.Message}", Alert.AlertType.Error);
        }
        finally
        {
            _addServiceId = 0;
            _isAddingService = false;
        }
    }

    private async Task CompleteAndPay()
    {
        if (_activeAppointment == null) return;

        _isProcessingPayment = true;

        try
        {
            // Complete the appointment via the proper API endpoint (In Progress → Completed)
            // If already completed (e.g. retry after payment failure), skip this step
            if (_activeAppointment.Status != "Completed")
            {
                var completedAppt = await AppointmentService.CompleteServiceAsync(_activeAppointment.AppointmentId);
                if (completedAppt == null)
                {
                    ShowAlert("Failed to complete appointment. Please try again.", Alert.AlertType.Error);
                    return;
                }
            }

            TransactionResponse? result = null;

            // Look up pending transaction if not already set (e.g. page refresh or state lost)
            if (_pendingTransaction == null)
            {
                try
                {
                    _pendingTransaction = await
                    TransactionService.GetPendingTransactionByAppointmentAsync(_activeAppointment.AppointmentId);
                }
                catch { /* will fall back to creating new txn */ }
            }

            // If a pending transaction exists, finalize it (Pending → Paid)
            if (_pendingTransaction != null)
            {
                var finalizeRequest = new FinalizePendingTransactionRequest
                {
                    PaymentMethod = _paymentMethod,
                    DiscountAmount = 0,
                    ProductItems = _checkoutProducts.Select(p => new CreateTransactionProductItemRequest
                    {
                        ProductId = p.ProductId,
                        Quantity = p.Quantity,
                        UnitPrice = p.Price
                    }).ToList()
                };

                result = await TransactionService.FinalizePendingTransactionAsync(_pendingTransaction.TransactionId, finalizeRequest);
            }
            else
            {
                // Fallback: create a new transaction directly (e.g., pending creation failed earlier)
                List<CreateTransactionServiceItemRequest> serviceItems;
                if (_activeAppointment.ServiceItems.Any())
                {
                    serviceItems = _activeAppointment.ServiceItems.Select(si => new CreateTransactionServiceItemRequest
                    {
                        ServiceId = si.ServiceId,
                        Quantity = si.Quantity,
                        UnitPrice = si.UnitPrice
                    }).ToList();
                }
                else
                {
                    serviceItems = new List<CreateTransactionServiceItemRequest>
{
new() { ServiceId = _activeAppointment.ServiceId, Quantity = 1, UnitPrice = _servicePrice }
};
                }

                var productItems = _checkoutProducts.Select(p => new CreateTransactionProductItemRequest
                {
                    ProductId = p.ProductId,
                    Quantity = p.Quantity,
                    UnitPrice = p.Price
                }).ToList();

                var transaction = new CreateTransactionRequest
                {
                    CustomerId = _activeAppointment.CustomerId,
                    AppointmentId = _activeAppointment.AppointmentId,
                    PaymentMethod = _paymentMethod,
                    DiscountAmount = 0,
                    ServiceItems = serviceItems,
                    ProductItems = productItems
                };

                result = await TransactionService.CreateTransactionAsync(transaction);
            }

            if (result != null)
            {
                // Store for success modal
                _lastTransactionNumber = result.TransactionNumber;
                _lastPaymentAmount = TotalAmount;
                _lastPaymentMethod = _paymentMethod;

                // Close progress modal and show success
                CloseProgressModal();
                _showPaymentSuccessModal = true;
                _pendingTransaction = null;

                await LoadAppointments();
            }
            else
            {
                ShowAlert("Failed to process payment. Please try again.", Alert.AlertType.Error);
            }
        }
        catch (Exception ex)
        {
            ShowAlert($"Error: {ex.Message}", Alert.AlertType.Error);
        }
        finally
        {
            _isProcessingPayment = false;
        }
    }

    private void PrintServiceReceipt()
    {
        // For now, just close the modal - receipt printing can be enhanced later
        _showPaymentSuccessModal = false;
    }

    public void Dispose()
    {
        _timer?.Dispose();
    }
}