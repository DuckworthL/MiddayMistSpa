        .btn-demo-primary {
            border-color: #3D5A4F;
            color: #3D5A4F;
            font-weight: 600;
        }

        /* ===== Right Panel: Illustration ===== */
        .illustration-panel {
            flex: 1;
            background: linear-gradient(135deg, #5A7B6D 0%, #3D5A4F 50%, #2A3F36 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
        }

        .illustration-content {
            position: relative;
            z-index: 2;
            text-align: center;
            padding: 3rem;
            width: 100%;
        }

        /* Floating background icons */
        .floating-icons {
            position: absolute;
            inset: 0;
            z-index: 1;
            pointer-events: none;
        }

        .float-icon {
            position: absolute;
            color: rgba(255, 255, 255, 0.08);
            font-size: 2rem;
            animation: floatIcon 6s ease-in-out infinite;
        }

        .float-icon-1 { top: 10%; left: 15%; animation-delay: 0s; font-size: 2.2rem; }
        .float-icon-2 { top: 8%; right: 20%; animation-delay: 1s; font-size: 1.8rem; }
        .float-icon-3 { top: 25%; left: 8%; animation-delay: 2s; }
        .float-icon-4 { top: 20%; right: 10%; animation-delay: 0.5s; font-size: 2.5rem; }
        .float-icon-5 { bottom: 30%; left: 12%; animation-delay: 1.5s; font-size: 2.2rem; }
        .float-icon-6 { bottom: 15%; right: 15%; animation-delay: 3s; }
        .float-icon-7 { bottom: 8%; left: 25%; animation-delay: 2.5s; font-size: 1.8rem; }
        .float-icon-8 { top: 45%; right: 8%; animation-delay: 4s; font-size: 1.6rem; }

        @@keyframes floatIcon {
            0%, 100% { transform: translateY(0) rotate(0deg); opacity: 0.08; }
            50% { transform: translateY(-12px) rotate(5deg); opacity: 0.15; }
        }

        /* Center illustration card */
        .illustration-card {
            position: relative;
            z-index: 2;
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.15);
            border-radius: 1.25rem;
            padding: 2.5rem 2rem;
            max-width: 340px;
            margin: 0 auto;
        }

        .illustration-card-icon {
            width: 56px;
            height: 56px;
            background: rgba(255, 255, 255, 0.2);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.25rem;
            font-size: 1.5rem;
            color: #D1B07D;
        }

        .illustration-card h3 {
            color: #ffffff;
            font-weight: 700;
            font-size: 1.35rem;
            margin-bottom: 0.5rem;
        }

        .illustration-card p {
            color: rgba(255, 255, 255, 0.75);
            font-size: 0.9rem;
            margin-bottom: 1.5rem;
        }

        .illustration-features {
            text-align: left;
        }

        .illust-feature {
            display: flex;
            align-items: center;
            gap: 0.6rem;
            padding: 0.45rem 0;
            color: rgba(255, 255, 255, 0.85);
            font-size: 0.85rem;
        }

        .illust-feature i {
            color: #D1B07D;
            font-size: 1rem;
            width: 1.25rem;
            text-align: center;
        }

        /* ===== Responsive ===== */
        @@media (max-width: 992px) {
            .illustration-panel {
                display: none;
            }

            .login-panel {
                padding: 2rem;
            }
        }

        @@media (max-width: 576px) {
            .login-panel {
                padding: 1.5rem;
            }

            .login-header h2 {
                font-size: 1.5rem;
            }
        }
    </style>

@code {
    private LoginModel _loginModel = new();
    private bool _isLoading;
    private bool _showPassword;
    private string? _errorMessage;
    private int? _remainingAttempts;
    private DateTime? _lockoutEnd;
    private bool _isRateLimited;
    private System.Threading.Timer? _lockoutTimer;

    // 2FA state
    private bool _requiresTwoFactor;
    private string? _twoFactorToken;
    private string? _twoFactorCode;
    private string? _recoveryCode;
    private bool _showRecoveryInput;

    // Captcha state
    private bool _captchaEnabled;
    private string? _captchaSiteKey;
    private string? _captchaError;
    private bool _captchaRendered;

    protected override async Task OnInitializedAsync()
    {
        // Check if already authenticated
        if (AuthService.IsAuthenticated)
        {
            Navigation.NavigateTo("/");
            return;
        }

        // Load captcha settings
        try
        {
            var settings = await CaptchaApi.GetSettingsAsync();
            if (settings != null)
            {
                _captchaEnabled = settings.Enabled;
                _captchaSiteKey = settings.SiteKey;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Failed to load captcha settings: {ex.Message}");
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_captchaEnabled && !string.IsNullOrEmpty(_captchaSiteKey) && !_captchaRendered && !_requiresTwoFactor)
        {
            try
            {
                await JS.InvokeVoidAsync("renderRecaptcha", _captchaSiteKey);
                _captchaRendered = true;
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Captcha render error: {ex.Message}");
            }
        }
    }

    private async Task HandleLogin()
    {
        _isLoading = true;
        _errorMessage = null;
        _captchaError = null;
        _isRateLimited = false;

        // Don't attempt if still locked out
        if (_lockoutEnd.HasValue && _lockoutEnd.Value > DateTime.UtcNow)
        {
            var remaining = _lockoutEnd.Value - DateTime.UtcNow;
            _errorMessage = $"Account is locked. Please wait {(int)remaining.TotalMinutes}m {remaining.Seconds}s.";
            _isLoading = false;
            return;
        }

        try
        {
            // Get captcha token if captcha is enabled
            string? captchaToken = null;
            if (_captchaEnabled && !string.IsNullOrEmpty(_captchaSiteKey))
            {
                try
                {
                    captchaToken = await JS.InvokeAsync<string>("getRecaptchaResponse");
                    if (string.IsNullOrEmpty(captchaToken))
                    {
                        _captchaError = "Please complete the CAPTCHA verification";
                        _isLoading = false;
                        return;
                    }
                }
                catch
                {
                    _captchaError = "CAPTCHA verification failed. Please try again.";
                    _isLoading = false;
                    return;
                }
            }

            var result = await AuthService.LoginAsync(_loginModel.Username, _loginModel.Password, captchaToken);

            if (result.Success)
            {
                Navigation.NavigateTo("/");
            }
            else if (result.RequiresTwoFactor)
            {
                _requiresTwoFactor = true;
                _twoFactorToken = result.TwoFactorToken;
                _twoFactorCode = null;
                _recoveryCode = null;
                _showRecoveryInput = false;
                _errorMessage = null;
            }
            else
            {
                var msg = result.ErrorMessage ?? "Invalid username or password. Please try again.";
                _remainingAttempts = result.RemainingAttempts;
                _lockoutEnd = result.LockoutEnd;

                // Detect rate limiter (middleware 429) vs account lockout
                _isRateLimited = msg.Contains("Too many requests", StringComparison.OrdinalIgnoreCase)
                    && !_lockoutEnd.HasValue;

                // Start countdown timer if locked out
                if (_lockoutEnd.HasValue && _lockoutEnd.Value > DateTime.UtcNow)
                {
                    StartLockoutTimer();
                }

                // Show CAPTCHA-specific errors in the captcha error area
                if (msg.Contains("CAPTCHA", StringComparison.OrdinalIgnoreCase))
                {
                    _captchaError = msg;
                }
                else
                {
                    _errorMessage = msg;
                }
                // Reset captcha after failed login
                await ResetCaptcha();
            }
        }
        catch (Exception ex)
        {
            _errorMessage = "An error occurred during login. Please try again.";
            Console.WriteLine($"Login error: {ex.Message}");
            await ResetCaptcha();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task HandleTwoFactorSubmit()
    {
        if (string.IsNullOrEmpty(_twoFactorCode) || _twoFactorCode.Length != 6 || string.IsNullOrEmpty(_twoFactorToken)) return;

        _isLoading = true;
        _errorMessage = null;

        try
        {
            var success = await AuthService.ValidateTwoFactorAsync(_twoFactorToken, _twoFactorCode);
            if (success)
            {
                Navigation.NavigateTo("/");
            }
            else
            {
                _errorMessage = "Invalid verification code. Please try again.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = "Verification failed. Please try again.";
            Console.WriteLine($"2FA error: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task HandleRecoverySubmit()
    {
        if (string.IsNullOrWhiteSpace(_recoveryCode) || string.IsNullOrEmpty(_twoFactorToken)) return;

        _isLoading = true;
        _errorMessage = null;

        try
        {
            var success = await AuthService.ValidateTwoFactorAsync(_twoFactorToken, "", _recoveryCode.Trim());
            if (success)
            {
                Navigation.NavigateTo("/");
            }
            else
            {
                _errorMessage = "Invalid recovery code. Please try again.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = "Verification failed. Please try again.";
            Console.WriteLine($"Recovery code error: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task HandleTwoFactorKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && _twoFactorCode?.Length == 6)
        {
            await HandleTwoFactorSubmit();
        }
    }

    private void BackToLogin()
    {
        _requiresTwoFactor = false;
        _twoFactorToken = null;
        _twoFactorCode = null;
        _recoveryCode = null;
        _errorMessage = null;
        _showRecoveryInput = false;
    }

    private void TogglePasswordVisibility()
    {
        _showPassword = !_showPassword;
    }

    private void FillDemoCredentials(string username, string password)
    {
        _loginModel.Username = username;
        _loginModel.Password = password;
        _errorMessage = null;
    }

    private async Task ResetCaptcha()
    {
        if (_captchaEnabled)
        {
            try
            {
                await JS.InvokeVoidAsync("resetRecaptcha");
            }
            catch { /* ignore */ }
        }
    }

    private void StartLockoutTimer()
    {
        _lockoutTimer?.Dispose();
        _lockoutTimer = new System.Threading.Timer(_ =>
        {
            InvokeAsync(() =>
            {
                if (_lockoutEnd.HasValue && _lockoutEnd.Value <= DateTime.UtcNow)
                {
                    _lockoutEnd = null;
                    _lockoutTimer?.Dispose();
                    _lockoutTimer = null;
                }
                StateHasChanged();
            });
        }, null, TimeSpan.Zero, TimeSpan.FromSeconds(1));
    }

    public void Dispose()
    {
        _lockoutTimer?.Dispose();
    }

    public class LoginModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Username is required")]
        public string Username { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Password is required")]
        public string Password { get; set; } = string.Empty;

        public bool RememberMe { get; set; }
    }
