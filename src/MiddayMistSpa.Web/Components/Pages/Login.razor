        }

        /* Demo credentials */
        .demo-credentials {
            padding-top: 1rem;
            border-top: 1px solid #E5E7EB;
        }

        .btn-demo {
            font-size: 0.72rem;
            padding: 0.3rem 0.55rem;
            border: 1px solid #D0D5DD;
            color: #344054;
            border-radius: 0.375rem;
            background: #ffffff;
            transition: all 0.15s;
        }

        .btn-demo:hover {
            background: #F3F4F6;
            border-color: #3D5A4F;
            color: #3D5A4F;
