@page "/login"
@layout EmptyLayout
@implements IDisposable
@inject IAuthStateService AuthService
@inject ICaptchaApiService CaptchaApi
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Login - MiddayMist Spa</PageTitle>

<div class="login-page">
    <div class="login-container">
        @* Left Side - Login Form *@
        <div class="login-panel">
            <div class="login-form-container">
                @* Brand Logo *@
                <div class="brand-logo-row">
                    <img src="images/logo.png" alt="MiddayMist Spa" class="brand-logo-img" />
                    <span class="brand-logo-text">MiddayMist Spa</span>
                </div>

                @* Welcome Header *@
                <div class="login-header">
                    <h2>Welcome back</h2>
                    <p>Please enter your details</p>
                </div>

                @if (_lockoutEnd.HasValue && _lockoutEnd.Value > DateTime.UtcNow)
                {
                    var remaining = _lockoutEnd.Value - DateTime.UtcNow;
                    <div class="alert alert-danger d-flex align-items-center py-2 border-0" role="alert" style="background-color: #f8d7da;">
                        <i class="bi bi-lock-fill me-2 fs-5"></i>
                        <div>
                            <strong>Account locked.</strong> Try again in
                            <span class="fw-bold">@((int)remaining.TotalMinutes)m @(remaining.Seconds.ToString("D2"))s</span>
                        </div>
                    </div>
                }
                else if (_isRateLimited)
                {
                    <div class="alert alert-danger d-flex align-items-center py-2 border-0" role="alert" style="background-color: #f8d7da;">
                        <i class="bi bi-shield-exclamation me-2 fs-5"></i>
                        <div>
                            <strong>Too many requests.</strong> You're sending requests too quickly.
                            Please wait <strong>1 minute</strong> before trying again.
                        </div>
                    </div>
                }

                @if (_remainingAttempts.HasValue && _remainingAttempts.Value > 0 && !(_lockoutEnd.HasValue && _lockoutEnd.Value > DateTime.UtcNow))
                {
                    var alertClass = _remainingAttempts.Value == 1 ? "alert-danger" : "alert-warning";
                    var icon = _remainingAttempts.Value == 1 ? "bi-exclamation-triangle-fill" : "bi-exclamation-circle";
                    <div class="alert @alertClass d-flex align-items-center py-2 border-0" role="alert">
                        <i class="bi @icon me-2"></i>
                        <div>
                            <strong>@_remainingAttempts attempt@(_remainingAttempts == 1 ? "" : "s") remaining</strong>
                            before your account is temporarily locked for 5 minutes.
                        </div>
                    </div>
                }

                @if (!string.IsNullOrEmpty(_errorMessage) && !_isRateLimited)
                {
                    <div class="alert alert-danger d-flex align-items-center py-2 border-0" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        <div>@_errorMessage</div>
                    </div>
                }

                @if (!_requiresTwoFactor)
                {
                    @* ===== STEP 1: Username & Password ===== *@
                    <EditForm Model="_loginModel" OnValidSubmit="HandleLogin" FormName="login">
                        <DataAnnotationsValidator />

                        <div class="mb-3">
                            <label class="form-label" for="username">Username</label>
                            <InputText @bind-Value="_loginModel.Username" class="form-control" id="username"
                                       placeholder="Enter your username" />
                            <ValidationMessage For="@(() => _loginModel.Username)" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label" for="password">Password</label>
                            <div class="password-input-wrapper">
                                <InputText @bind-Value="_loginModel.Password" type="@(_showPassword ? "text" : "password")"
                                           class="form-control" id="password" placeholder="Enter your password" />
                                <button type="button" class="password-toggle-btn" @onclick="TogglePasswordVisibility"
                                        tabindex="-1">
                                    <i class="bi @(_showPassword ? "bi-eye-slash" : "bi-eye")"></i>
                                </button>
                            </div>
                            <ValidationMessage For="@(() => _loginModel.Password)" />
                        </div>

                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="rememberMe"
                                       @bind="_loginModel.RememberMe">
                                <label class="form-check-label small" for="rememberMe">
                                    Remember for 30 days
                                </label>
                            </div>
                            <a href="/forgot-password" class="forgot-link">Forgot password</a>
                        </div>

                        @if (_captchaEnabled && !string.IsNullOrEmpty(_captchaSiteKey))
                        {
                            <div class="mb-3 d-flex justify-content-center">
                                <div id="recaptcha-container"></div>
                            </div>
                            @if (!string.IsNullOrEmpty(_captchaError))
                            {
                                <div class="alert alert-warning py-2 small mb-3">
                                    <i class="bi bi-exclamation-triangle me-1"></i>@_captchaError
                                </div>
                            }
                        }

                        <button type="submit" class="btn btn-login w-100" disabled="@(_isLoading || (_lockoutEnd.HasValue && _lockoutEnd.Value > DateTime.UtcNow))">
                            @if (_isLoading)
                            {
                                <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                <span>Signing in...</span>
                            }
                            else
                            {
                                <span>Sign in</span>
                            }
                        </button>
                    </EditForm>
                }
                else
                {
                    @* ===== STEP 2: Two-Factor Code ===== *@
                    <div class="two-factor-step">
                        <div class="text-center mb-4">
                            <div class="twofa-icon-circle mx-auto mb-3">
                                <i class="bi bi-shield-lock fs-3"></i>
                            </div>
                            <h5 class="fw-semibold mb-1">Two-Factor Authentication</h5>
                            <p class="text-muted small mb-0">Enter the 6-digit code from your authenticator app</p>
                        </div>

                        @if (!_showRecoveryInput)
                        {
                            <div class="mx-auto mb-4" style="max-width: 220px;">
                                <input type="text" class="form-control form-control-lg text-center twofa-input"
                                       maxlength="6" placeholder="000000"
                                       @bind="_twoFactorCode" @bind:event="oninput"
                                       @onkeydown="HandleTwoFactorKeyDown" />
                            </div>
                            <button class="btn btn-login w-100 mb-3" @onclick="HandleTwoFactorSubmit"
                                    disabled="@(_twoFactorCode?.Length != 6 || _isLoading)">
                                @if (_isLoading)
                                {
                                    <span class="spinner-border spinner-border-sm me-2"></span>
                                    <span>Verifying...</span>
                                }
                                else
                                {
                                    <i class="bi bi-check-circle me-1"></i>
                                    <span>Verify</span>
                                }
                            </button>
                            <div class="text-center">
                                <button class="btn btn-link btn-sm text-muted" @onclick="() => _showRecoveryInput = true">
                                    Use a recovery code instead
                                </button>
                            </div>
                        }
                        else
                        {
                            <div class="mb-4">
                                <label class="form-label small text-muted">Recovery Code</label>
                                <input type="text" class="form-control text-center"
                                       placeholder="XXXX-XXXX" @bind="_recoveryCode" @bind:event="oninput"
                                       style="letter-spacing: 3px; font-weight: 600;" />
                            </div>
                            <button class="btn btn-login w-100 mb-3" @onclick="HandleRecoverySubmit"
                                    disabled="@(string.IsNullOrWhiteSpace(_recoveryCode) || _isLoading)">
                                @if (_isLoading)
                                {
                                    <span class="spinner-border spinner-border-sm me-2"></span>
                                    <span>Verifying...</span>
                                }
                                else
                                {
                                    <i class="bi bi-check-circle me-1"></i>
                                    <span>Verify Recovery Code</span>
                                }
                            </button>
                            <div class="text-center">
                                <button class="btn btn-link btn-sm text-muted" @onclick="() => _showRecoveryInput = false">
                                    Use authenticator code instead
                                </button>
                            </div>
                        }

                        <div class="text-center mt-2">
                            <button class="btn btn-link btn-sm text-muted" @onclick="BackToLogin">
                                <i class="bi bi-arrow-left me-1"></i> Back to login
                            </button>
                        </div>
                    </div>
                }

                @* Demo Credentials *@
                <div class="demo-credentials mt-4">
                    <p class="text-center text-muted small mb-2">Demo Credentials</p>
                    <div class="d-flex gap-2 flex-wrap justify-content-center">
                        <button class="btn btn-demo btn-demo-primary"
                                @onclick='() => FillDemoCredentials("superadmin", "SuperAdmin@2026!")'>
                            <i class="bi bi-shield-fill-check me-1"></i>Super Admin
                        </button>
                        <button class="btn btn-demo"
                                @onclick='() => FillDemoCredentials("admin", "Admin@2026!")'>
                            <i class="bi bi-shield-check me-1"></i>Admin
                        </button>
                        <button class="btn btn-demo"
                                @onclick='() => FillDemoCredentials("receptionist", "Receptionist@2026!")'>
                            <i class="bi bi-person-workspace me-1"></i>Receptionist
                        </button>
                    </div>
                    <div class="d-flex gap-2 flex-wrap justify-content-center mt-2">
                        <button class="btn btn-demo"
                                @onclick='() => FillDemoCredentials("therapist", "Therapist@2026!")'>
                            <i class="bi bi-heart-pulse me-1"></i>Therapist
                        </button>
                        <button class="btn btn-demo"
                                @onclick='() => FillDemoCredentials("inventory", "Inventory@2026!")'>
                            <i class="bi bi-box-seam me-1"></i>Inventory
                        </button>
                        <button class="btn btn-demo"
                                @onclick='() => FillDemoCredentials("accountant", "Accountant@2026!")'>
                            <i class="bi bi-calculator me-1"></i>Accountant
                        </button>
                        <button class="btn btn-demo"
                                @onclick='() => FillDemoCredentials("hr", "HR@2026!")'>
                            <i class="bi bi-people me-1"></i>HR
                        </button>
                        <button class="btn btn-demo"
                                @onclick='() => FillDemoCredentials("salesledger", "SalesLedger@2026!")'>
                            <i class="bi bi-journal-text me-1"></i>Sales Ledger
                        </button>
                    </div>
                </div>
            </div>
        </div>

        @* Right Side - Illustration Panel *@
        <div class="illustration-panel">
            <div class="illustration-content">
                @* Floating background icons *@
                <div class="floating-icons">
                    <div class="float-icon float-icon-1"><i class="bi bi-calendar-check"></i></div>
                    <div class="float-icon float-icon-2"><i class="bi bi-people"></i></div>
                    <div class="float-icon float-icon-3"><i class="bi bi-graph-up"></i></div>
                    <div class="float-icon float-icon-4"><i class="bi bi-clock"></i></div>
                    <div class="float-icon float-icon-5"><i class="bi bi-envelope"></i></div>
                    <div class="float-icon float-icon-6"><i class="bi bi-headset"></i></div>
                    <div class="float-icon float-icon-7"><i class="bi bi-chat-dots"></i></div>
                    <div class="float-icon float-icon-8"><i class="bi bi-gem"></i></div>
                </div>

                @* Center feature card *@
                <div class="illustration-card">
                    <div class="illustration-card-icon">
                        <i class="bi bi-check-lg"></i>
                    </div>
                    <h3>Manage Your Spa</h3>
                    <p>Appointments, customers, inventory, payroll — all in one place.</p>
                    <div class="illustration-features">
                        <div class="illust-feature">
                            <i class="bi bi-calendar-check"></i>
                            <span>Appointment Scheduling</span>
                        </div>
                        <div class="illust-feature">
                            <i class="bi bi-people"></i>
                            <span>Customer Management</span>
                        </div>
                        <div class="illust-feature">
                            <i class="bi bi-cash-coin"></i>
                            <span>Point of Sale</span>
                        </div>
                        <div class="illust-feature">
                            <i class="bi bi-bar-chart"></i>
                            <span>Business Analytics</span>
                        </div>
                        <div class="illust-feature">
                            <i class="bi bi-person-badge"></i>
                            <span>HR & Payroll</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

    <style>
        .login-page {
            min-height: 100vh;
            background: #ffffff;
            display: flex;
            align-items: stretch;
        }

        .login-container {
            display: flex;
            flex-direction: row-reverse;
            width: 100%;
            min-height: 100vh;
        }

        /* ===== Left Panel: Form ===== */
        .login-panel {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 3rem 4rem;
            background: #ffffff;
        }

        .login-form-container {
            width: 100%;
            max-width: 420px;
        }

        .brand-logo-row {
            display: flex;
            align-items: center;
            gap: 0.6rem;
            margin-bottom: 2.5rem;
        }

        .brand-logo-img {
            width: 36px;
            height: 36px;
            object-fit: contain;
        }

        .brand-logo-text {
            font-size: 1.15rem;
            font-weight: 700;
            color: #2C2C2C;
            letter-spacing: -0.01em;
        }

        .login-header {
            margin-bottom: 1.75rem;
        }

        .login-header h2 {
            color: #1a1a1a;
            font-weight: 700;
            font-size: 1.85rem;
            margin-bottom: 0.35rem;
        }

        .login-header p {
            color: #6B7280;
            font-size: 0.95rem;
            margin-bottom: 0;
        }

        .form-label {
            font-size: 0.875rem;
            font-weight: 500;
            color: #344054;
            margin-bottom: 0.4rem;
        }

        .form-control {
            height: 2.85rem;
            border: 1px solid #D0D5DD;
            border-radius: 0.5rem;
            font-size: 0.95rem;
            padding: 0.5rem 0.875rem;
            transition: border-color 0.2s, box-shadow 0.2s;
        }

        .form-control:focus {
            border-color: #3D5A4F;
            box-shadow: 0 0 0 3px rgba(61, 90, 79, 0.12);
        }

        .form-control::placeholder {
            color: #9CA3AF;
        }

        .password-input-wrapper {
            position: relative;
        }

        .password-input-wrapper .form-control {
            padding-right: 2.75rem;
        }

        .password-toggle-btn {
            position: absolute;
            right: 10px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            color: #9CA3AF;
            cursor: pointer;
            padding: 0.25rem;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: color 0.2s;
            z-index: 5;
        }

        .password-toggle-btn:hover {
            color: #3D5A4F;
        }

        .form-check-input:checked {
            background-color: #3D5A4F;
            border-color: #3D5A4F;
        }

        .forgot-link {
            font-size: 0.875rem;
            font-weight: 500;
            color: #3D5A4F;
            text-decoration: none;
        }

        .forgot-link:hover {
            text-decoration: underline;
            color: #2A3F36;
        }

        .btn-login {
            background: #3D5A4F;
            color: #ffffff;
            border: none;
            border-radius: 0.5rem;
            padding: 0.7rem 1rem;
            font-size: 0.95rem;
            font-weight: 600;
            transition: background 0.2s, box-shadow 0.2s;
        }

        .btn-login:hover {
            background: #2A3F36;
            color: #ffffff;
        }

        .btn-login:disabled {
            background: #8BA49A;
            color: #ffffff;
        }

        /* Two-factor styling */
        .twofa-icon-circle {
            width: 64px;
            height: 64px;
            background: rgba(61, 90, 79, 0.1);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #3D5A4F;
        }

        .twofa-input {
            letter-spacing: 8px;
            font-size: 1.5rem;
