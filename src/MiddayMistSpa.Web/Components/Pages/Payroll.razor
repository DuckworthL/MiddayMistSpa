@page "/payroll"
@inject IEmployeeApiService EmployeeService
@inject IPayrollApiService PayrollService
@inject IReportsApiService ReportsService
@inject IRolePermissionService RolePermissionService
@inject IAuthStateService AuthService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<PageTitle>Payroll - MiddayMist Spa</PageTitle>

<AuthorizedPage OnAuthReady="InitializeData">
    <div class="container-fluid">
        @* Page Header *@
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1 class="h3 mb-1">Payroll Management</h1>
                <p class="text-muted mb-0">Process payroll and manage compensation</p>
            </div>
            <div class="d-flex gap-2">
                @if (_canManage)
                {
                    <button class="btn btn-outline-primary" @onclick="ShowBonusModal">
                        <i class="bi bi-gift me-1"></i> Add Bonus
                    </button>
                    <button class="btn btn-outline-info" @onclick="ShowPreviewModal">
                        <i class="bi bi-eye me-1"></i> Preview Payroll
                    </button>
                    <button class="btn btn-primary" @onclick="ShowRunPayrollModal">
                        <i class="bi bi-play-fill me-1"></i> Run Payroll
                    </button>
                }
            </div>
        </div>

        @* Pay Period Selector *@
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body">
                <div class="row g-3 align-items-center">
                    <div class="col-auto">
                        <div class="btn-group">
                            <button class="btn btn-outline-secondary" @onclick="PreviousPeriod">
                                <i class="bi bi-chevron-left"></i>
                            </button>
                            <button class="btn btn-outline-secondary" @onclick="CurrentPeriod">Current</button>
                            <button class="btn btn-outline-secondary" @onclick="NextPeriod"
                                    disabled="@(_periodEnd >= PhilippineTime.Today)">
                                <i class="bi bi-chevron-right"></i>
                            </button>
                        </div>
                    </div>
                    <div class="col">
                        <h5 class="mb-0">
                            @_periodStart.ToString("MMM dd") - @_periodEnd.ToString("MMM dd, yyyy")
                            @if (_periodEnd >= PhilippineTime.Today)
                            {
                                <span class="badge bg-primary ms-2">Current Period</span>
                            }
                        </h5>
                    </div>
                    <div class="col-auto">
                        <span class="badge bg-@(_payrollStatus == "Processed" ? "success" : "warning") fs-6">
                            @_payrollStatus
                        </span>
                    </div>
                </div>
            </div>
        </div>

        @* Summary Cards *@
        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <StatCard Title="Total Payroll" Value="@_totalPayroll.ToString("C")" Icon="bi-wallet2"
                          Color="StatCard.CardColor.Primary" />
            </div>
            <div class="col-md-3">
                <StatCard Title="Employees" Value="@_employeeCount.ToString()" Icon="bi-people"
                          Color="StatCard.CardColor.Info" />
            </div>
            <div class="col-md-3">
                <StatCard Title="Total Hours" Value="@_totalHours.ToString("N0")" Icon="bi-clock-history"
                          Color="StatCard.CardColor.Success" />
            </div>
            <div class="col-md-3">
                <StatCard Title="Bonuses/Deductions" Value="@_totalAdjustments.ToString("C")" Icon="bi-plus-slash-minus"
                          Color="StatCard.CardColor.Warning" />
            </div>
        </div>

        @if (_isLoading)
        {
            <LoadingSpinner Message="Loading payroll data..." />
        }
        else
        {
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-transparent d-flex justify-content-between align-items-center">
                    <span>Employee Payroll</span>
                    <div class="d-flex gap-2">
                        <select class="form-select form-select-sm" style="width: auto;" @bind="_exportFormat">
                            <option value="PDF">PDF</option>
                            <option value="Excel">Excel</option>
                            <option value="CSV">CSV</option>
                        </select>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="ExportPayroll" disabled="@_isExporting">
                            @if (_isExporting)
                            {
                                <span class="spinner-border spinner-border-sm me-1"></span>
                            }
                            else
                            {
                                <i class="bi bi-download me-1"></i>
                            }
                            Export
                        </button>
                    </div>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Employee</th>
                                    <th>Position</th>
                                    <th class="text-center">Hours Worked</th>
                                    <th class="text-end">Hourly Rate</th>
                                    <th class="text-end">Regular Pay</th>
                                    <th class="text-end">Bonus/Comm</th>
                                    <th class="text-end">Deductions</th>
                                    <th class="text-end">Employer Cost</th>
                                    <th class="text-end">Net Pay</th>
                                    <th class="text-center">Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (_payrollItems.Any())
                                {
                                    @foreach (var item in _payrollItems)
                                    {
                                        <tr>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-2"
                                                         style="width: 35px; height: 35px; font-size: 0.8rem;">
                                                        @item.Initials
                                                    </div>
                                                    <div>
                                                        <div class="fw-medium">@item.EmployeeName</div>
                                                        <small class="text-muted">@item.EmployeeCode</small>
                                                    </div>
                                                </div>
                                            </td>
                                            <td>@item.Position</td>
                                            <td class="text-center">
                                                @item.RegularHours
                                                @if (item.OvertimeHours > 0)
                                                {
                                                    <span class="text-warning small"> +@item.OvertimeHours OT</span>
                                                }
                                            </td>
                                            <td class="text-end">@item.HourlyRate.ToString("C")</td>
                                            <td class="text-end">@item.RegularPay.ToString("C")</td>
                                            <td class="text-end">
                                                @if (item.Bonus > 0 || item.Commission > 0)
                                                {
                                                    <span class="text-success">+@((item.Bonus + item.Commission).ToString("C"))</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td class="text-end"
                                                title="SSS: @item.SSSContribution.ToString("N2") | PhilHealth: @item.PhilHealthContribution.ToString("N2") | Pag-IBIG: @item.PagIBIGContribution.ToString("N2") | Tax: @item.WithholdingTax.ToString("N2")">
                                                @if (item.Deductions > 0)
                                                {
                                                    <span class="text-danger">-@item.Deductions.ToString("C")</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td class="text-end"
                                                title="SSS ER: @item.SSSEmployerContribution.ToString("N2") | PhilHealth ER: @item.PhilHealthEmployerContribution.ToString("N2") | Pag-IBIG ER: @item.PagIBIGEmployerContribution.ToString("N2") | EC: @item.ECContribution.ToString("N2")">
                                                @if (item.TotalEmployerContributions > 0)
                                                {
                                                    <span class="text-info">@item.TotalEmployerContributions.ToString("C")</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td class="text-end fw-bold">@item.NetPay.ToString("C")</td>
                                            <td class="text-center">
                                                @if (item.IsPaid)
                                                {
                                                    <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Paid</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-warning">Pending</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                    <tr class="table-light fw-bold">
                                        <td colspan="4">Total</td>
                                        <td class="text-end">@_payrollItems.Sum(p => p.RegularPay).ToString("C")</td>
                                        <td class="text-end text-success">+@_payrollItems.Sum(p => p.Bonus +
                                                                                p.Commission).ToString("C")</td>
                                            <td class="text-end text-danger">-@_payrollItems.Sum(p => p.Deductions).ToString("C")
                                            </td>
                                            <td class="text-end text-info">@_payrollItems.Sum(p =>
                                                                                    p.TotalEmployerContributions).ToString("C")
                                            </td>
                                            <td class="text-end">@_payrollItems.Sum(p => p.NetPay).ToString("C")</td>
                                            <td></td>
                                        </tr>
                                    }
                            else
                                    {
                                        <tr>
                                            <td colspan="10" class="text-center py-5">
                                                <i class="bi bi-wallet display-4 text-muted"></i>
                                                <p class="text-muted mt-2">No payroll data for this period</p>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                @* Payroll History *@
                <div class="card border-0 shadow-sm mt-4">
                    <div class="card-header bg-transparent">
                        <h6 class="mb-0">Recent Payroll History</h6>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-sm mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Pay Period</th>
                                        <th>Employees</th>
                                        <th class="text-end">Total Paid</th>
                                        <th>Processed By</th>
                                        <th>Date Processed</th>
                                        <th class="text-end">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var history in _payrollHistory)
                                    {
                                        <tr>
                                            <td>@history.PeriodStart.ToString("MMM dd") - @history.PeriodEnd.ToString("MMM dd,         yyyy")
                                            </td>
                                            <td>@history.EmployeeCount</td>
                                            <td class="text-end fw-medium">@history.TotalPaid.ToString("C")</td>
                                            <td>@history.ProcessedBy</td>
                                            <td>@history.ProcessedDate.ToString("MMM dd, yyyy")</td>
                                            <td class="text-end">
                                                <button class="btn btn-sm btn-outline-primary"
                                                        @onclick="() => ViewPayrollDetails(history)">
                                                    <i class="bi bi-eye"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
        </div>

        @* Run Payroll Modal *@
        <Modal @bind-IsVisible="_showRunPayrollModal" Title="Run Payroll">
            <ChildContent>
                <div class="alert alert-info">
                    <i class="bi bi-info-circle me-2"></i>
                    You are about to process payroll for:
                    <strong>@_periodStart.ToString("MMM dd") - @_periodEnd.ToString("MMM dd, yyyy")</strong>
                </div>

                <div class="mb-4">
                    <h6>Payroll Summary</h6>
                    <div class="row text-center">
                        <div class="col">
                            <div class="h4 mb-0">@_employeeCount</div>
                            <small class="text-muted">Employees</small>
                        </div>
                        <div class="col">
                            <div class="h4 mb-0">@_totalHours.ToString("N0")</div>
                            <small class="text-muted">Total Hours</small>
                        </div>
                        <div class="col">
                            <div class="h4 mb-0 text-primary">@_totalPayroll.ToString("C")</div>
                            <small class="text-muted">Total Payroll</small>
                        </div>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Payment Method</label>
                    <select class="form-select" @bind="_paymentMethod">
                        <option value="Direct Deposit">Direct Deposit</option>
                        <option value="Check">Check</option>
                        <option value="Cash">Cash</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label">Notes</label>
                    <textarea class="form-control" rows="2" @bind="_payrollNotes"
                              placeholder="Optional notes..."></textarea>
                </div>

                <div class="mb-3">
                    <label class="form-label">Payroll Scope</label>
                    <div class="btn-group w-100">
                        <button class="btn @(_payrollMode == "all" ? "btn-primary" : "btn-outline-primary")"
                                @onclick='() => _payrollMode = "all"'>
                            <i class="bi bi-people me-1"></i> All Employees
                        </button>
                        <button class="btn @(_payrollMode == "selected" ? "btn-primary" : "btn-outline-primary")"
                                @onclick='() => _payrollMode = "selected"'>
                            <i class="bi bi-person-check me-1"></i> Selected Employees
                        </button>
                    </div>
                </div>

                @if (_payrollMode == "selected")
                {
                    <div class="mb-3">
                        <label class="form-label">Select Employees</label>
                        <div class="border rounded p-2" style="max-height: 200px; overflow-y: auto;">
                            @foreach (var emp in _employeeLookup)
                            {
                                <div class="form-check">
                                    <input type="checkbox" class="form-check-input" id="emp-@emp.Id"
                                           checked="@_selectedEmployeeIds.Contains(emp.Id)"
                                           @onchange="(e) => ToggleEmployeeSelection(emp.Id, (bool)(e.Value ?? false))" />
                                    <label class="form-check-label" for="emp-@emp.Id">@emp.Name</label>
                                </div>
                            }
                        </div>
                        @if (_payrollMode == "selected" && !_selectedEmployeeIds.Any())
                        {
                            <small class="text-danger">Please select at least one employee.</small>
                        }
                    </div>
                }

                <div class="form-check">
                    <input type="checkbox" class="form-check-input" id="confirmPayroll" @bind="_payrollConfirmed" />
                    <label class="form-check-label" for="confirmPayroll">
                        I confirm that all payroll information is accurate and ready to process
                    </label>
                </div>
            </ChildContent>
            <FooterContent>
                <button type="button" class="btn btn-secondary"
                        @onclick="() => _showRunPayrollModal = false">Cancel</button>
                <button type="button" class="btn btn-success" @onclick="ProcessPayroll"
                        disabled="@(!_payrollConfirmed || _isProcessing || (_payrollMode == "selected" && !_selectedEmployeeIds.Any()))">
                    @if (_isProcessing)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                    }
                    <i class="bi bi-check-lg me-1"></i> Process Payroll
                </button>
            </FooterContent>
        </Modal>

        @* Add Bonus Modal *@
        <Modal @bind-IsVisible="_showBonusModal" Title="Add Bonus/Deduction">
            <ChildContent>
                <div class="mb-3">
                    <label class="form-label">Employee *</label>
                    <select class="form-select" @bind="_bonusForm.EmployeeId">
                        <option value="0">Select Employee...</option>
                        @foreach (var emp in _employeeLookup)
                        {
                            <option value="@emp.Id">@emp.Name</option>
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">Type *</label>
                    <div class="btn-group w-100">
                        <button class="btn @(_bonusForm.IsBonus ? "btn-success" : "btn-outline-success")"
                                @onclick="() => _bonusForm.IsBonus = true">
                            <i class="bi bi-plus me-1"></i> Bonus
                        </button>
                        <button class="btn @(!_bonusForm.IsBonus ? "btn-danger" : "btn-outline-danger")"
                                @onclick="() => _bonusForm.IsBonus = false">
                            <i class="bi bi-dash me-1"></i> Deduction
                        </button>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Amount *</label>
                    <div class="input-group">
                        <span class="input-group-text">₱</span>
                        <input type="number" class="form-control" @bind="_bonusForm.Amount" min="0" step="0.01" />
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Reason *</label>
                    <input type="text" class="form-control" @bind="_bonusForm.Reason"
                           placeholder="e.g., Performance bonus, Holiday pay..." />
                </div>
            </ChildContent>
            <FooterContent>
                <button type="button" class="btn btn-secondary" @onclick="() => _showBonusModal = false">Cancel</button>
                <button type="button" class="btn btn-primary" @onclick="SaveBonus" disabled="@_isSaving">
                    @if (_isSaving)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                    }
                    Save
                </button>
            </FooterContent>
        </Modal>

        @* Payroll Detail Modal *@
        @if (_showPayrollDetailModal && _detailHistory != null)
        {
            <div class="modal fade show d-block" tabindex="-1" style="z-index: 1055; background-color: rgba(0,0,0,0.5);">
                <div class="modal-dialog modal-xl modal-dialog-scrollable">
                    <div class="modal-content">
                        <div class="modal-header bg-primary text-white">
                            <h5 class="modal-title">
                                <i class="bi bi-file-earmark-text me-2"></i>Payroll Summary
                            </h5>
                            <button type="button" class="btn-close btn-close-white" @onclick="ClosePayrollDetailModal"></button>
                        </div>
                        <div class="modal-body" id="payroll-detail-content">
                            @* Header Info *@
                            <div class="row mb-4">
                                <div class="col-md-6">
                                    <h4 class="text-primary mb-1">MiddayMist Spa & Wellness</h4>
                                    <p class="text-muted mb-0">Payroll Report</p>
                                </div>
                                <div class="col-md-6 text-md-end">
                                    <div class="mb-1">
                                        <strong>Pay Period:</strong>
                                        @_detailHistory.PeriodStart.ToString("MMM dd") - @_detailHistory.PeriodEnd.ToString("MMM dd, yyyy")
                                    </div>
                                    <div class="mb-1">
                                        <strong>Processed:</strong> @_detailHistory.ProcessedDate.ToString("MMM dd, yyyy")
                                    </div>
                                    <div>
                                        <strong>Processed By:</strong> @_detailHistory.ProcessedBy
                                    </div>
                                </div>
                            </div>

                            <hr />

                            @* Summary Cards *@
                            <div class="row g-3 mb-4">
                                <div class="col-md-3">
                                    <div class="border rounded p-3 text-center">
                                        <div class="text-muted small">Total Gross Pay</div>
                                        <div class="h5 mb-0 text-primary">@_detailItems.Sum(x => x.GrossPay).ToString("C")</div>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="border rounded p-3 text-center">
                                        <div class="text-muted small">Total Deductions</div>
                                        <div class="h5 mb-0 text-danger">@_detailItems.Sum(x => x.Deductions).ToString("C")
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="border rounded p-3 text-center">
                                        <div class="text-muted small">Employer Costs</div>
                                        <div class="h5 mb-0 text-info">@_detailItems.Sum(x =>
                                                                                x.TotalEmployerContributions).ToString("C")</div>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="border rounded p-3 text-center">
                                            <div class="text-muted small">Total Net Pay</div>
                                            <div class="h5 mb-0 text-success fw-bold">@_detailItems.Sum(x => x.NetPay).ToString("C")
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                @* Employee Breakdown Table *@
                                <h6 class="mb-3"><i class="bi bi-people me-1"></i> Employee Breakdown (@_detailItems.Count
                                    employees)</h6>
                                    <div class="table-responsive">
                                        <table class="table table-sm table-bordered mb-4">
                                            <thead class="table-light">
                                                <tr>
                                                    <th>Employee</th>
                                                    <th>Position</th>
                                                    <th class="text-center">Hours</th>
                                                    <th class="text-end">Gross Pay</th>
                                                    <th class="text-end">Bonus/Comm</th>
                                                    <th class="text-end">SSS</th>
                                                    <th class="text-end">PhilHealth</th>
                                                    <th class="text-end">Pag-IBIG</th>
                                                    <th class="text-end">Tax</th>
                                                    <th class="text-end">Total Ded.</th>
                                                    <th class="text-end fw-bold">Net Pay</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var item in _detailItems)
                                                {
                                                    <tr>
                                                        <td>
                                                            <div class="fw-medium">@item.EmployeeName</div>
                                                            <small class="text-muted">@item.EmployeeCode</small>
                                                        </td>
                                                        <td>@item.Position</td>
                                                        <td class="text-center">
                                                            @item.RegularHours.ToString("N2")
                                                            @if (item.OvertimeHours > 0)
                                                            {
                                                                <br />

                                                                <small class="text-warning">+@item.OvertimeHours.ToString("N2") OT</small>
                                                            }
                                                        </td>
                                                        <td class="text-end">@item.GrossPay.ToString("N2")</td>
                                                        <td class="text-end">
                                                            @if (item.Bonus + item.Commission > 0)
                                                            {
                                                                <span class="text-success">@((item.Bonus +
                                                                                                                item.Commission).ToString("N2"))</span>
                                                                }
                                        else
                                                                {
                                                                    <span class="text-muted">-</span>
                                                                }
                                                            </td>
                                                            <td class="text-end">@item.SSSContribution.ToString("N2")</td>
                                                            <td class="text-end">@item.PhilHealthContribution.ToString("N2")</td>
                                                            <td class="text-end">@item.PagIBIGContribution.ToString("N2")</td>
                                                            <td class="text-end">@item.WithholdingTax.ToString("N2")</td>
                                                            <td class="text-end text-danger">@item.Deductions.ToString("N2")</td>
                                                            <td class="text-end fw-bold">@item.NetPay.ToString("N2")</td>
                                                        </tr>
                                                    }
                                                </tbody>
                                                <tfoot class="table-light fw-bold">
                                                    <tr>
                                                        <td colspan="3">Totals</td>
                                                        <td class="text-end">@_detailItems.Sum(x => x.GrossPay).ToString("N2")</td>
                                                        <td class="text-end text-success">@_detailItems.Sum(x => x.Bonus +
                                                                                                    x.Commission).ToString("N2")</td>
                                                            <td class="text-end">@_detailItems.Sum(x => x.SSSContribution).ToString("N2")</td>
                                                            <td class="text-end">@_detailItems.Sum(x => x.PhilHealthContribution).ToString("N2")
                                                            </td>
                                                            <td class="text-end">@_detailItems.Sum(x => x.PagIBIGContribution).ToString("N2")
                                                            </td>
                                                            <td class="text-end">@_detailItems.Sum(x => x.WithholdingTax).ToString("N2")</td>
                                                            <td class="text-end text-danger">@_detailItems.Sum(x => x.Deductions).ToString("N2")
                                                            </td>
                                                            <td class="text-end">@_detailItems.Sum(x => x.NetPay).ToString("N2")</td>
                                                        </tr>
                                                    </tfoot>
                                                </table>
                                            </div>

                                            @* Employer Contributions Breakdown *@
                                            <h6 class="mb-3"><i class="bi bi-building me-1"></i> Employer Contributions</h6>
                                            <div class="table-responsive">
                                                <table class="table table-sm table-bordered mb-0">
                                                    <thead class="table-light">
                                                        <tr>
                                                            <th>Employee</th>
                                                            <th class="text-end">SSS (ER)</th>
                                                            <th class="text-end">PhilHealth (ER)</th>
                                                            <th class="text-end">Pag-IBIG (ER)</th>
                                                            <th class="text-end">EC</th>
                                                            <th class="text-end fw-bold">Total ER Cost</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var item in _detailItems)
                                                        {
                                                            <tr>
                                                                <td>@item.EmployeeName</td>
