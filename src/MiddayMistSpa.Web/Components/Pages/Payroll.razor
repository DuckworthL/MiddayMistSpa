    private void ToggleEmployeeSelection(int employeeId, bool isChecked)
    {
        if (isChecked && !_selectedEmployeeIds.Contains(employeeId))
            _selectedEmployeeIds.Add(employeeId);
        else if (!isChecked)
            _selectedEmployeeIds.Remove(employeeId);
    }

    private async Task ProcessPayroll()
    {
        _isProcessing = true;

        try
        {
            var employeeIds = _payrollMode == "selected" && _selectedEmployeeIds.Any() ? _selectedEmployeeIds : null;

            if (_currentPeriodId.HasValue && (_payrollStatus == "Processed" || _payrollStatus == "Paid"))
            {
                // Period already processed — check if we can add selected employees
                if (employeeIds == null || !employeeIds.Any())
                {
                    ShowAlert("This period has already been processed. Select specific employees or use the navigation arrows to select a different period.",
                    Alert.AlertType.Warning);
                    _showRunPayrollModal = false;
                    _isProcessing = false;
                    return;
                }

                // Check which selected employees already have records
                var existingIds = _payrollItems.Select(p => p.EmployeeId).ToHashSet();
                var newEmployeeIds = employeeIds.Where(id => !existingIds.Contains(id)).ToList();

                if (!newEmployeeIds.Any())
                {
                    ShowAlert("All selected employees already have payroll records for this period.",
                    Alert.AlertType.Warning);
                    _showRunPayrollModal = false;
                    _isProcessing = false;
                    return;
                }

                // Reopen the period, generate for new employees, then re-finalize
                var reopened = await PayrollService.ReopenPayrollPeriodAsync(_currentPeriodId.Value);
                if (reopened == null)
                {
                    ShowAlert("Failed to reopen payroll period. Please try again.", Alert.AlertType.Error);
                    _isProcessing = false;
                    return;
                }

                var (generated, genError) = await PayrollService.GeneratePayrollRecordsWithErrorAsync(
                    _currentPeriodId.Value, newEmployeeIds);
                if (!generated)
                {
                    ShowAlert(genError ?? "Failed to generate payroll records. Please try again.", Alert.AlertType.Error);
                    _isProcessing = false;
                    return;
                }

                var (result, finalizeError) = await PayrollService.FinalizePayrollPeriodWithErrorAsync(_currentPeriodId.Value);
                if (result != null)
                {
                    _payrollStatus = "Processed";
                    ShowAlert("Payroll processed successfully for the selected employees!", Alert.AlertType.Success);
                    _showRunPayrollModal = false;
                    await LoadPayrollData();
                }
                else
                {
                    ShowAlert(finalizeError ?? "Failed to finalize payroll. Please try again.", Alert.AlertType.Error);
                }
            }
            else
            {
                if (!_currentPeriodId.HasValue)
                {
                    // Create a new payroll period first
                    var periodRequest = new CreatePayrollPeriodRequest
                    {
                        PeriodName = $"Payroll {_periodStart:MMM dd} - {_periodEnd:MMM dd, yyyy}",
                        StartDate = _periodStart,
                        EndDate = _periodEnd,
                        PayrollType = "Semi-Monthly",
                        CutoffDate = _periodEnd,
                        PaymentDate = _periodEnd.AddDays(5)
                    };

                    var period = await PayrollService.CreatePayrollPeriodAsync(periodRequest);
                    if (period != null)
                    {
                        _currentPeriodId = period.PayrollPeriodId;
                        var (generated, genError) = await PayrollService.GeneratePayrollRecordsWithErrorAsync(
                            period.PayrollPeriodId, employeeIds);
                        if (!generated)
                        {
                            ShowAlert(genError ?? "Failed to generate payroll records. Please try again.", Alert.AlertType.Error);
                            _isProcessing = false;
                            return;
                        }
                    }
                }

                if (_currentPeriodId.HasValue)
                {
                    // Finalize the payroll period
                    var (result, finalizeError) = await PayrollService.FinalizePayrollPeriodWithErrorAsync(_currentPeriodId.Value);
                    if (result != null)
                    {
                        _payrollStatus = "Processed";
                        ShowAlert("Payroll processed successfully!", Alert.AlertType.Success);
                        _showRunPayrollModal = false;
                        await LoadPayrollData();
                    }
                    else
                    {
                        ShowAlert(finalizeError ?? "Failed to finalize payroll. Please try again.", Alert.AlertType.Error);
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"ProcessPayroll error: {ex.Message}");
            ShowAlert("An unexpected error occurred while processing payroll.", Alert.AlertType.Error);
        }

        _isProcessing = false;
    }

