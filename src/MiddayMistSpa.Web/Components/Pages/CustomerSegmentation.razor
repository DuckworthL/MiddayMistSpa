@code {
    private bool _isLoading = true;
    private bool _isAnalyzing = false;
    private bool _isRecalculating = false;
    private bool _showGuide = true;
    private bool _showPipeline = true;
    private string? _errorMessage;
    private string? _successMessage;

    // Export state
    private bool _isExporting = false;

    // Segment modal state
    private bool _showSegmentModal = false;
    private bool _isLoadingSegmentCustomers = false;
    private CustomerSegmentResponse? _selectedSegment;
    private List<CustomerListItem> _segmentCustomers = new();

    // Parameters
    private DbscanParametersRequest _parameters = new()
    {
        Epsilon = 0.15,
        MinSamples = 2,
        NormalizeData = true,
        RecencyWeight = 1.0,
        FrequencyWeight = 1.0,
        MonetaryWeight = 1.0
    };

    // Results
    private ClusteringStatusResponse? _clusteringStatus;
    private ClusteringResultResponse? _analysisResult;
    private List<CustomerSegmentResponse>? _segments;

    protected override void OnInitialized()
    {
        // Data will be loaded via OnAuthReady callback
    }

    private async Task LoadData()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            // Load current status and segments
            var statusTask = SegmentationService.GetClusteringStatusAsync();
            var segmentsTask = SegmentationService.GetAllSegmentsAsync();

            await Task.WhenAll(statusTask, segmentsTask);

            _clusteringStatus = await statusTask;
            _segments = await segmentsTask;
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error loading segmentation data: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task RunAnalysis()
    {
        _isAnalyzing = true;
        _errorMessage = null;
        _successMessage = null;
        StateHasChanged();

        try
        {
            _analysisResult = await SegmentationService.RunDbscanAnalysisAsync(_parameters);

            if (_analysisResult?.Success == true)
            {
                _successMessage = $"Analysis complete! Found {_analysisResult.ClustersFound} clusters from {_analysisResult.TotalCustomersAnalyzed} customers.";
                // Reload the data to get updated segments
                await LoadData();
            }
            else
            {
                _errorMessage = _analysisResult?.Message ?? "Analysis failed";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error running analysis: {ex.Message}";
        }
        finally
        {
            _isAnalyzing = false;
        }
    }

    private async Task RecalculateStats()
    {
        _isRecalculating = true;
        _errorMessage = null;
        StateHasChanged();

        try
        {
            await SegmentationService.RecalculateSegmentStatsAsync();
            _successMessage = "Segment statistics recalculated successfully";
            await LoadData();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error recalculating: {ex.Message}";
        }
        finally
        {
            _isRecalculating = false;
        }
    }

    private async Task ViewSegmentCustomers(CustomerSegmentResponse segment)
    {
        _selectedSegment = segment;
        _showSegmentModal = true;
        _isLoadingSegmentCustomers = true;
        _segmentCustomers = new();
        StateHasChanged();

        try
        {
            _segmentCustomers = await SegmentationService.GetCustomersBySegmentAsync(segment.SegmentName);
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error loading segment customers: {ex.Message}";
        }
        finally
        {
            _isLoadingSegmentCustomers = false;
            StateHasChanged();
        }
    }

    private async Task ExportAllPdf() => await ExportSegmentation("PDF", null);
    private async Task ExportAllExcel() => await ExportSegmentation("Excel", null);
    private async Task ExportSegPdf(string segName) => await ExportSegmentation("PDF", segName);
    private async Task ExportSegExcel(string segName) => await ExportSegmentation("Excel", segName);

    private void CloseSegmentModal()
    {
        _showSegmentModal = false;
        _selectedSegment = null;
        _segmentCustomers = new();
    }

    private async Task ExportSegmentation(string format, string? segmentName)
    {
        if (_isExporting) return;
        _isExporting = true;
        _errorMessage = null;
        _successMessage = null;

        try
        {
            var (fileContent, fileName, contentType, error) = await SegmentationService.ExportSegmentationAsync(format, segmentName);

            if (fileContent == null || error != null)
            {
                _errorMessage = error ?? "Export failed. Please try again.";
                return;
            }

            var base64 = Convert.ToBase64String(fileContent);
            await JSRuntime.InvokeVoidAsync("downloadFile", fileName, contentType, base64);

            var scope = string.IsNullOrEmpty(segmentName) ? "All Segments" : segmentName;
            _successMessage = $"✔ {format} report exported for {scope}.";
        }
        catch (Exception ex)
        {
            _errorMessage = $"Export error: {ex.Message}";
        }
        finally
        {
            _isExporting = false;
        }
    }

    private string GetMembershipBadge(string type) => type switch
    {
        "Platinum" => "bg-dark text-white",
        "Gold" => "bg-warning text-dark",
        "Silver" => "bg-secondary text-white",
        _ => "bg-light text-dark border"
    };

    private string GetSegmentColor(string segmentCode) => segmentCode switch
    {
        "VIP" => "#8B5CF6", // Purple
        "LYL" => "#10B981", // Green
        "PRM" => "#3B82F6", // Blue
        "NEW" => "#06B6D4", // Cyan
        "RSK" => "#F59E0B", // Amber
        "HIB" => "#EF4444", // Red
        "LST" => "#6B7280", // Gray
        "OUT" => "#94A3B8", // Slate
        _ => "#6B7280"
    };

    private string GetSegmentIcon(string segmentCode) => segmentCode switch
    {
        "VIP" => "💎",
        "LYL" => "🌟",
        "PRM" => "📈",
        "NEW" => "🌱",
        "RSK" => "⚠️",
        "HIB" => "😴",
        "LST" => "👋",
        "OUT" => "❓",
        _ => "👤"
    };

    private string GetScoreColor(double score) => score switch
    {
        >= 80 => "#10B981", // Green
        >= 60 => "#3B82F6", // Blue
        >= 40 => "#F59E0B", // Amber
        _ => "#EF4444"      // Red
    };

    private string GetSilhouetteColor(double score) => score switch
    {
        >= 0.5 => "#10B981",  // Strong structure
        >= 0.25 => "#3B82F6", // Reasonable structure
        >= 0 => "#F59E0B",    // Weak structure
        _ => "#EF4444"        // Misclassified
    };

    private string GetDbiColor(double dbi) => dbi switch
    {
        <= 0.5 => "#10B981",
        <= 1.0 => "#3B82F6",
        <= 2.0 => "#F59E0B",
        _ => "#EF4444"
    };
}