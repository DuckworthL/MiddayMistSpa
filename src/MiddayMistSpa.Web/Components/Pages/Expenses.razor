@page "/accounting/expenses"
@inject IAuthStateService AuthService
@inject IRolePermissionService RolePermissionService
@inject IAccountingApiService AccountingService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@using MiddayMistSpa.Web.Models

<PageTitle>Expenses - MiddayMist Spa</PageTitle>

<AuthorizedPage OnAuthReady="LoadData">
    <div class="container-fluid fade-in">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-1">
                        <li class="breadcrumb-item"><a href="/accounting">Accounting</a></li>
                        <li class="breadcrumb-item active">Expenses</li>
                    </ol>
                </nav>
                <h1 class="h3 mb-0" style="color: #2C2C2C;">Expense Management</h1>
            </div>
            <button class="btn btn-primary" @onclick="ShowAddModal">
                <i class="bi bi-plus-lg me-1"></i> Record Expense
            </button>
        </div>

        @* Summary Cards *@
        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <div class="card bg-danger bg-opacity-10 border-0">
                    <div class="card-body text-center">
                        <p class="text-muted mb-1 small">This Month</p>
                        <h4 class="text-danger mb-0">₱@_monthTotal.ToString("N2")</h4>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 bg-light">
                    <div class="card-body text-center">
                        <p class="text-muted mb-1 small">Last Month</p>
                        <h4 class="mb-0">₱@_lastMonthTotal.ToString("N2")</h4>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 bg-light">
                    <div class="card-body text-center">
                        <p class="text-muted mb-1 small">Pending Approval</p>
                        <h4 class="text-warning mb-0">@_pendingCount</h4>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 bg-light">
                    <div class="card-body text-center">
                        <p class="text-muted mb-1 small">YTD Total</p>
                        <h4 class="mb-0">₱@_ytdTotal.ToString("N2")</h4>
                    </div>
                </div>
            </div>
        </div>

        @* Filters *@
        <div class="card mb-4">
            <div class="card-body py-3">
                <div class="row g-3">
                    <div class="col-md-3">
                        <input type="text" class="form-control" placeholder="Search expenses..." @bind="_searchTerm"
                            @bind:event="oninput" />
                    </div>
                    <div class="col-md-2">
                        <select class="form-select" @bind="_categoryFilter">
                            <option value="">All Categories</option>
                            @foreach (var cat in _categories)
                            {
                                <option value="@cat">@cat</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <select class="form-select" @bind="_statusFilter">
                            <option value="">All Status</option>
                            <option value="Approved">Approved</option>
                            <option value="Pending">Pending</option>
                            <option value="Rejected">Rejected</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <input type="date" class="form-control" @bind="_dateFrom" @bind:after="LoadData" />
                    </div>
                    <div class="col-md-2">
                        <input type="date" class="form-control" @bind="_dateTo" @bind:after="LoadData" />
                    </div>
                    <div class="col-md-1">
                        <button class="btn btn-outline-secondary w-100" @onclick="ExportExpenses">
                            <i class="bi bi-download"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>

        @* Expenses Table *@
        <div class="card">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Entry #</th>
                                <th>Date</th>
                                <th>Description</th>
                                <th>Category</th>
                                <th>Vendor</th>
                                <th>Status</th>
                                <th class="text-end">Amount</th>
                                <th style="width: 100px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (_isLoading)
                            {
                                <tr>
                                    <td colspan="8" class="text-center py-5">
                                        <div class="spinner-border text-primary" role="status"></div>
                                    </td>
                                </tr>
                            }
                            else if (!FilteredExpenses.Any())
                            {
                                <tr>
                                    <td colspan="8" class="text-center py-5 text-muted">
                                        No expenses found
                                    </td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var expense in FilteredExpenses)
                                {
                                    <tr>
                                        <td><span class="text-primary fw-medium">@expense.EntryNumber</span></td>
                                        <td>@expense.Date.ToString("MMM dd, yyyy")</td>
                                        <td>@expense.Description</td>
                                        <td><span class="badge bg-light text-dark">@expense.Category</span></td>
                                        <td>@expense.Vendor</td>
                                        <td>
                                            <span class="badge @GetStatusBadge(expense.Status)">@expense.Status</span>
                                        </td>
                                        <td class="text-end fw-medium text-danger">₱@expense.Amount.ToString("N2")</td>
                                        <td>
                                            <button class="btn btn-link btn-sm p-1" @onclick="() => ViewExpense(expense)">
                                                <i class="bi bi-eye text-info"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    @* Add Modal *@
    @if (_showModal)
    {
        <div class="modal show d-block" style="background: rgba(0,0,0,0.5);">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Record Expense</h5>
                        <button type="button" class="btn-close" @onclick="CloseModal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Date</label>
                                <input type="date" class="form-control" @bind="_formModel.Date" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Amount</label>
                                <div class="input-group">
                                    <span class="input-group-text">₱</span>
                                    <input type="number" class="form-control" @bind="_formModel.Amount" step="0.01" />
                                </div>
                            </div>
                            <div class="col-12">
                                <label class="form-label">Description</label>
                                <input type="text" class="form-control" @bind="_formModel.Description" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Expense Account</label>
                                <select class="form-select" @bind="_formModel.ExpenseAccountId">
                                    <option value="0">-- Select Expense Account --</option>
                                    @foreach (var account in _accounts.Where(a => a.AccountType == "Expense"))
                                    {
                                        <option value="@account.AccountId">@account.AccountCode - @account.AccountName</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Payment Account</label>
                                <select class="form-select" @bind="_formModel.PaymentAccountId">
                                    <option value="0">-- Select Payment Account --</option>
                                    @foreach (var account in _accounts.Where(a => a.AccountType == "Asset"))
                                    {
                                        <option value="@account.AccountId">@account.AccountCode - @account.AccountName</option>
                                    }
                                </select>
                            </div>
                            <div class="col-12">
                                <label class="form-label">Vendor/Supplier</label>
                                <input type="text" class="form-control" @bind="_formModel.Vendor" />
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-secondary" @onclick="CloseModal">Cancel</button>
                        <button class="btn btn-primary" @onclick="SaveExpense">Save Expense</button>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (_showDetailModal && _selectedExpense != null)
    {
        <div class="modal show d-block" style="background: rgba(0,0,0,0.5);">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Expense Details</h5>
                        <button type="button" class="btn-close" @onclick="() => _showDetailModal = false"></button>
                    </div>
                    <div class="modal-body">
                        <dl class="row mb-0">
                            <dt class="col-sm-4">Entry #</dt>
                            <dd class="col-sm-8">@_selectedExpense.EntryNumber</dd>
                            <dt class="col-sm-4">Date</dt>
                            <dd class="col-sm-8">@_selectedExpense.Date.ToString("MMM dd, yyyy")</dd>
                            <dt class="col-sm-4">Description</dt>
                            <dd class="col-sm-8">@(_selectedExpense.Description ?? "—")</dd>
                            <dt class="col-sm-4">Vendor</dt>
                            <dd class="col-sm-8">@(_selectedExpense.Vendor ?? "—")</dd>
                            <dt class="col-sm-4">Category</dt>
                            <dd class="col-sm-8">@_selectedExpense.Category</dd>
                            <dt class="col-sm-4">Amount</dt>
                            <dd class="col-sm-8 fw-bold text-danger">₱@_selectedExpense.Amount.ToString("N2")</dd>
                            <dt class="col-sm-4">Status</dt>
                            <dd class="col-sm-8"><span class="badge @GetStatusBadge(_selectedExpense.Status)">@_selectedExpense.Status</span></dd>
                            <dt class="col-sm-4">Created By</dt>
                            <dd class="col-sm-8">@_selectedExpense.CreatedByName</dd>
                        </dl>
                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-secondary" @onclick="() => _showDetailModal = false">Close</button>
                    </div>
                </div>
            </div>
        </div>
    }
</AuthorizedPage>

@code {
    private List<string> _categories = new() { "Salary Expense", "Cost of Goods Sold", "Supplies Expense",
"Rent Expense", "Utilities Expense", "Other" };

    private List<ExpenseResponse> _expenses = new();
    private List<ChartOfAccountResponse> _accounts = new();
    private bool _isLoading = true;

    private string _searchTerm = "";
    private string _categoryFilter = "";
    private string _statusFilter = "";
    private DateTime? _dateFrom;
    private DateTime? _dateTo;

    private decimal _monthTotal = 0m;
    private decimal _lastMonthTotal = 0m;
    private decimal _ytdTotal = 0m;
    private int _pendingCount = 0;
    private int _currentPage = 1;
    private int _totalPages = 1;

    private bool _showModal = false;
    private bool _showDetailModal = false;
    private ExpenseResponse? _selectedExpense;
    private ExpenseFormModel _formModel = new();

    protected override void OnInitialized()
    {
        // Data loading moved to LoadData, triggered by AuthorizedPage.OnAuthReady
    }

    private async Task LoadData()
    {
        _isLoading = true;
        StateHasChanged();
        try
        {
            var response = await AccountingService.GetExpensesAsync(
            startDate: _dateFrom,
            endDate: _dateTo,
            page: _currentPage,
            pageSize: 20);

            _expenses = response.Items;
            _totalPages = response.TotalPages;

            // Load summary stats from server (computed from full dataset)
            var summary = await AccountingService.GetExpenseSummaryAsync();
            if (summary != null)
            {
                _monthTotal = summary.MonthTotal;
                _lastMonthTotal = summary.LastMonthTotal;
                _ytdTotal = summary.YtdTotal;
                _pendingCount = summary.PendingCount;
            }

            // Load accounts for dropdown
            _accounts = await AccountingService.GetAccountsHierarchyAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading expenses: {ex.Message}");
            _expenses = new List<ExpenseResponse>();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private IEnumerable<ExpenseResponse> FilteredExpenses => _expenses.Where(e =>
    (string.IsNullOrEmpty(_searchTerm) ||
    (e.Description?.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
    (e.Vendor?.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ?? false)) &&
    (string.IsNullOrEmpty(_categoryFilter) || e.Category == _categoryFilter) &&
    (string.IsNullOrEmpty(_statusFilter) || e.Status == _statusFilter)
    );

    private string GetStatusBadge(string status) => status switch
    {
        "Approved" or "Posted" => "bg-success",
        "Pending" or "Draft" => "bg-warning text-dark",
        "Rejected" or "Voided" => "bg-danger",
        _ => "bg-secondary"
    };

    private void ShowAddModal()
    {
        _formModel = new ExpenseFormModel { Date = PhilippineTime.Now };
        _showModal = true;
    }

    private void ViewExpense(ExpenseResponse expense)
    {
        _selectedExpense = expense;
        _showDetailModal = true;
    }

    private void CloseModal() => _showModal = false;

    private async Task SaveExpense()
    {
        try
        {
            var request = new CreateExpenseRequest
            {
                Date = _formModel.Date,
                Description = _formModel.Description,
                Vendor = _formModel.Vendor,
                ExpenseAccountId = _formModel.ExpenseAccountId,
                PaymentAccountId = _formModel.PaymentAccountId,
                Amount = _formModel.Amount
            };

            await AccountingService.CreateExpenseAsync(request);
            _showModal = false;
            await LoadData();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error saving expense: {ex.Message}");
        }
    }

    private async Task ExportExpenses()
    {
        try
        {
            var q = '"';
            var sb = new System.Text.StringBuilder();
            sb.AppendLine("MiddayMist Spa - Expense Report");
            var fromLabel = _dateFrom?.ToString("MMM dd, yyyy") ?? "All";
            var toLabel = _dateTo?.ToString("MMM dd, yyyy") ?? "Present";
            sb.AppendLine($"Period: {fromLabel} to {toLabel}");
            sb.AppendLine($"Generated: {PhilippineTime.Now:MMM dd, yyyy hh:mm tt}");
            sb.AppendLine();
            sb.AppendLine("Entry #,Date,Description,Vendor,Category,Amount,Status,Created By");
            foreach (var e in _expenses.OrderByDescending(e => e.Date))
            {
                var desc = (e.Description ?? "").Replace(q.ToString(), "'");
                sb.AppendLine($"{q}{e.EntryNumber}{q},{e.Date:yyyy-MM-dd},{q}{desc}{q},{q}{e.Vendor ?? ""}{q},{q}{e.Category}{q},{e.Amount:F2},{e.Status},{q}{e.CreatedByName}{q}");
            }
            sb.AppendLine();
            sb.AppendLine($"Total Expenses,,,,,{_expenses.Sum(e => e.Amount):F2},,");
            var bytes = System.Text.Encoding.UTF8.GetBytes(sb.ToString());
            var base64 = Convert.ToBase64String(bytes);
            await JSRuntime.InvokeVoidAsync("downloadFile", $"Expenses_{PhilippineTime.Now:yyyyMMdd}.csv", "text/csv", base64);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Export failed: {ex.Message}");
        }
    }

    private class ExpenseFormModel
    {
        public DateTime Date { get; set; } = PhilippineTime.Now;
        public string Description { get; set; } = "";
        public string? Vendor { get; set; }
        public int ExpenseAccountId { get; set; }
        public int PaymentAccountId { get; set; }
        public decimal Amount { get; set; }
    }
}