@page "/accounting/invoices"
@inject IAuthStateService AuthService
@inject IRolePermissionService RolePermissionService
@inject IAccountingApiService AccountingService
@inject ICustomerApiService CustomerService
@inject NavigationManager Navigation

<PageTitle>Invoices - MiddayMist Spa</PageTitle>

<AuthorizedPage>
    <div class="container-fluid fade-in">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-1">
                        <li class="breadcrumb-item"><a href="/accounting">Accounting</a></li>
                        <li class="breadcrumb-item active">Invoices</li>
                    </ol>
                </nav>
                <h1 class="h3 mb-0" style="color: #2C2C2C;">Invoices</h1>
            </div>
            <button class="btn btn-primary" @onclick="ShowCreateModal">
                <i class="bi bi-plus-lg me-1"></i> Create Invoice
            </button>
        </div>

        @* Summary Cards *@
        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <div class="card border-0 bg-light">
                    <div class="card-body text-center">
                        <p class="text-muted mb-1 small">Total Invoiced</p>
                        <h4 class="mb-0">₱@_totalInvoiced.ToString("N2")</h4>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 bg-success bg-opacity-10">
                    <div class="card-body text-center">
                        <p class="text-muted mb-1 small">Paid</p>
                        <h4 class="text-success mb-0">₱@_totalPaid.ToString("N2")</h4>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 bg-warning bg-opacity-10">
                    <div class="card-body text-center">
                        <p class="text-muted mb-1 small">Pending</p>
                        <h4 class="text-warning mb-0">₱@_totalPending.ToString("N2")</h4>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 bg-danger bg-opacity-10">
                    <div class="card-body text-center">
                        <p class="text-muted mb-1 small">Overdue</p>
                        <h4 class="text-danger mb-0">₱@_totalOverdue.ToString("N2")</h4>
                    </div>
                </div>
            </div>
        </div>

        @* Filters *@
        <div class="card mb-4">
            <div class="card-body py-3">
                <div class="row g-3">
                    <div class="col-md-3">
                        <input type="text" class="form-control" placeholder="Search invoices..." @bind="_searchTerm"
                               @bind:event="oninput" />
                    </div>
                    <div class="col-md-2">
                        <select class="form-select" @bind="_statusFilter">
                            <option value="">All Status</option>
                            <option value="Paid">Paid</option>
                            <option value="Pending">Pending</option>
                            <option value="Overdue">Overdue</option>
                            <option value="Draft">Draft</option>
                            <option value="Cancelled">Cancelled</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <input type="date" class="form-control" @bind="_dateFrom" />
                    </div>
                    <div class="col-md-2">
                        <input type="date" class="form-control" @bind="_dateTo" />
                    </div>
                    <div class="col-md-2 ms-auto">
                        <button class="btn btn-outline-secondary w-100">
                            <i class="bi bi-download me-1"></i> Export
                        </button>
                    </div>
                </div>
            </div>
        </div>

        @* Invoices Table *@
        <div class="card">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Invoice #</th>
                                <th>Customer</th>
                                <th>Issue Date</th>
                                <th>Due Date</th>
                                <th>Status</th>
                                <th class="text-end">Amount</th>
                                <th style="width: 120px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (_isLoading)
                            {
                                <tr>
                                    <td colspan="7" class="text-center py-5">
                                        <div class="spinner-border text-primary" role="status"></div>
                                    </td>
                                </tr>
                            }
                            else if (!_invoices.Any())
                            {
                                <tr>
                                    <td colspan="7" class="text-center py-5 text-muted">No invoices found</td>
                                </tr>
                            }
                            @foreach (var invoice in _invoices)
                            {
                                <tr>
                                    <td>
                                        <span class="fw-medium">@invoice.InvoiceNumber</span>
                                    </td>
                                    <td>@invoice.CustomerName</td>
                                    <td>@invoice.InvoiceDate.ToString("MMM dd, yyyy")</td>
                                    <td
                                        class="@(invoice.DueDate < PhilippineTime.Today && invoice.Status != "Paid" ? "text-danger" : "")">
                                        @invoice.DueDate.ToString("MMM dd, yyyy")
                                    </td>
                                    <td>
                                        <span class="badge @GetStatusBadge(invoice.Status)">@invoice.Status</span>
                                    </td>
                                    <td class="text-end fw-medium">₱@invoice.Total.ToString("N2")</td>
                                    <td>
                                        <button class="btn btn-link btn-sm p-1" @onclick="() => ViewInvoice(invoice)"
                                                title="View">
                                            <i class="bi bi-eye text-info"></i>
                                        </button>
                                        @if (invoice.Status is "Sent" or "Partial" or "Overdue")
                                        {
                                            <button class="btn btn-link btn-sm p-1" @onclick="() => MarkAsPaid(invoice)"
                                                    title="Mark as Paid">
                                                <i class="bi bi-check-circle text-success"></i>
                                            </button>
                                        }
                                        @if (invoice.Status == "Draft")
                                        {
                                            <button class="btn btn-link btn-sm p-1" @onclick="() => SendInvoice(invoice)"
                                                    title="Send">
                                                <i class="bi bi-send text-primary"></i>
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    @* Create Invoice Modal *@
    @if (_showModal)
    {
        <div class="modal show d-block" style="background: rgba(0,0,0,0.5);">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Create Invoice</h5>
                        <button type="button" class="btn-close" @onclick="() => _showModal = false"></button>
                    </div>
                    <div class="modal-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Customer</label>
                                <select class="form-select" @bind="_newInvoice.CustomerId">
                                    <option value="0">Select Customer</option>
                                    @foreach (var c in _customers)
                                    {
                                        <option value="@c.CustomerId">@c.FirstName @c.LastName</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Due Date</label>
                                <input type="date" class="form-control" @bind="_newInvoice.DueDate" />
                            </div>
                            <div class="col-12">
                                <label class="form-label">Items</label>
                                <table class="table table-sm">
                                    <thead>
                                        <tr>
                                            <th>Description</th>
                                            <th style="width: 80px;">Qty</th>
                                            <th style="width: 120px;">Price</th>
                                            <th style="width: 120px;">Total</th>
                                            <th style="width: 40px;"></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in _newInvoiceLines)
                                        {
                                            <tr>
                                                <td><input type="text" class="form-control form-control-sm"
                                                               @bind="item.Description" /></td>
                                                    <td><input type="number" class="form-control form-control-sm"
                                                                   @bind="item.Quantity" /></td>
                                                        <td><input type="number" class="form-control form-control-sm"
                                                                       @bind="item.UnitPrice" /></td>
                                                            <td class="text-end align-middle">₱@((item.Quantity *
                                                                                                                                                                            item.UnitPrice).ToString("N2"))</td>
                                                                <td>
                                                                    <button class="btn btn-link btn-sm text-danger p-0"
                                                                            @onclick="() => RemoveItem(item)">
                                                                        <i class="bi bi-x"></i>
                                                                    </button>
                                                                </td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>
                                                <button class="btn btn-outline-secondary btn-sm" @onclick="AddItem">
                                                    <i class="bi bi-plus me-1"></i> Add Item
                                                </button>
                                            </div>
                                            <div class="col-12">
                                                <label class="form-label">Notes</label>
                                                <textarea class="form-control" rows="2" @bind="_newInvoiceNotes"></textarea>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="modal-footer">
                                        <div class="me-auto">
                                            <strong>Total: ₱@_newInvoiceLines.Sum(i => i.Quantity * i.UnitPrice).ToString("N2")</strong>
                                        </div>
                                        <button class="btn btn-secondary" @onclick="() => _showModal = false">Cancel</button>
                                        <button class="btn btn-outline-primary" @onclick="SaveAsDraft">Save as Draft</button>
                                        <button class="btn btn-primary" @onclick="CreateAndSend">Create & Send</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }

                    @if (_showDetailModal && _selectedInvoice != null)
                    {
                        <div class="modal show d-block" style="background: rgba(0,0,0,0.5);">
                            <div class="modal-dialog modal-lg">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <h5 class="modal-title">Invoice @_selectedInvoice.InvoiceNumber</h5>
                                        <button type="button" class="btn-close" @onclick="() => _showDetailModal = false"></button>
                                    </div>
                                    <div class="modal-body">
                                        <div class="row mb-3">
                                            <div class="col-md-6">
                                                <dl class="row mb-0">
                                                    <dt class="col-sm-5">Customer</dt>
                                                    <dd class="col-sm-7">@_selectedInvoice.CustomerName</dd>
                                                    <dt class="col-sm-5">Invoice Date</dt>
                                                    <dd class="col-sm-7">@_selectedInvoice.InvoiceDate.ToString("MMM dd, yyyy")</dd>
                                                    <dt class="col-sm-5">Due Date</dt>
                                                    <dd class="col-sm-7">@_selectedInvoice.DueDate.ToString("MMM dd, yyyy")</dd>
                                                </dl>
                                            </div>
                                            <div class="col-md-6 text-end">
                                                <span class="badge @GetStatusBadge(_selectedInvoice.Status) fs-6">@_selectedInvoice.Status</span>
                                            </div>
                                        </div>
                                        @if (_selectedInvoice.Lines?.Any() == true)
                                        {
                                            <table class="table table-sm">
                                                <thead><tr><th>Description</th><th class="text-end">Qty</th><th class="text-end">Price</th><th class="text-end">Amount</th></tr></thead>
                                                <tbody>
                                                    @foreach (var line in _selectedInvoice.Lines)
                                                    {
                                                        <tr>
                                                            <td>@line.Description</td>
                                                            <td class="text-end">@line.Quantity</td>
                                                            <td class="text-end">₱@line.UnitPrice.ToString("N2")</td>
                                                            <td class="text-end">₱@line.Amount.ToString("N2")</td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        }
                                        <div class="border-top pt-2">
                                            <div class="row"><div class="col-8 text-end">Subtotal:</div><div class="col-4 text-end">₱@_selectedInvoice.Subtotal.ToString("N2")</div></div>
                                            <div class="row"><div class="col-8 text-end">Tax:</div><div class="col-4 text-end">₱@_selectedInvoice.Tax.ToString("N2")</div></div>
                                            <div class="row fw-bold"><div class="col-8 text-end">Total:</div><div class="col-4 text-end">₱@_selectedInvoice.Total.ToString("N2")</div></div>
                                            <div class="row text-success"><div class="col-8 text-end">Paid:</div><div class="col-4 text-end">₱@_selectedInvoice.AmountPaid.ToString("N2")</div></div>
                                            <div class="row fw-bold"><div class="col-8 text-end">Balance:</div><div class="col-4 text-end">₱@_selectedInvoice.Balance.ToString("N2")</div></div>
                                        </div>
                                    </div>
                                    <div class="modal-footer">
                                        <button class="btn btn-secondary" @onclick="() => _showDetailModal = false">Close</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </AuthorizedPage>

@code {
    private List<InvoiceResponse> _invoices = new();
    private List<CustomerResponse> _customers = new();

    private string _searchTerm = "";
    private string _statusFilter = "";
    private DateTime? _dateFrom;
    private DateTime? _dateTo;
    private int _currentPage = 1;
    private int _totalPages = 1;
    private bool _isLoading;

    private decimal _totalInvoiced;
    private decimal _totalPaid;
    private decimal _totalPending;
    private decimal _totalOverdue;

    private bool _showModal = false;
    private bool _showDetailModal = false;
    private InvoiceResponse? _selectedInvoice;
    private CreateInvoiceRequest _newInvoice = new();
    private List<CreateInvoiceLineRequest> _newInvoiceLines = new() { new() { Quantity = 1 } };
    private string _newInvoiceNotes = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadInvoices();
        var customerResult = await CustomerService.GetCustomersAsync(page: 1, pageSize: 200);
        _customers = customerResult.Items;
    }

    private async Task LoadInvoices()
    {
        _isLoading = true;
        StateHasChanged();
        try
        {
            var result = await AccountingService.GetInvoicesAsync(
                status: string.IsNullOrEmpty(_statusFilter) ? null : _statusFilter,
                page: _currentPage,
                pageSize: 20);
            _invoices = result.Items;
            _totalPages = result.TotalPages;

            _totalInvoiced = _invoices.Sum(i => i.Total);
            _totalPaid = _invoices.Where(i => i.Status == "Paid").Sum(i => i.Total);
            _totalPending = _invoices.Where(i => i.Status is "Draft" or "Sent" or "Partial").Sum(i => i.Total);
            _totalOverdue = _invoices.Where(i => i.Status == "Overdue").Sum(i => i.Total);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private string GetStatusBadge(string status) => status switch
    {
        "Paid" => "bg-success",
        "Sent" => "bg-warning text-dark",
        "Partial" => "bg-info",
        "Overdue" => "bg-danger",
        "Draft" => "bg-secondary",
        "Cancelled" => "bg-dark",
        _ => "bg-secondary"
    };

    private void ShowCreateModal()
    {
        _newInvoice = new CreateInvoiceRequest
        {
            InvoiceDate = PhilippineTime.Today,
            DueDate = PhilippineTime.Today.AddDays(15)
        };
        _newInvoiceLines = new List<CreateInvoiceLineRequest> { new() { Quantity = 1 } };
        _newInvoiceNotes = "";
        _showModal = true;
    }

    private void AddItem()
    {
        _newInvoiceLines.Add(new CreateInvoiceLineRequest { Quantity = 1 });
    }

    private void RemoveItem(CreateInvoiceLineRequest item)
    {
        if (_newInvoiceLines.Count > 1)
            _newInvoiceLines.Remove(item);
    }

    private async Task SaveAsDraft()
    {
        await CreateInvoiceInternal();
    }

    private async Task CreateAndSend()
    {
        try
        {
            var invoice = await CreateInvoiceInternal();
            if (invoice != null)
                await AccountingService.UpdateInvoiceStatusAsync(invoice.InvoiceId, "Sent");
            await LoadInvoices();
        }
        catch (Exception)
        {
            // LoadInvoices already handles errors
        }
    }

    private async Task<InvoiceResponse?> CreateInvoiceInternal()
    {
        if (_newInvoice.CustomerId <= 0 || !_newInvoiceLines.Any(l => !string.IsNullOrWhiteSpace(l.Description)))
            return null;

        _newInvoice.Lines = _newInvoiceLines.Where(l => !string.IsNullOrWhiteSpace(l.Description)).ToList();
        _newInvoice.Notes = _newInvoiceNotes;
        var result = await AccountingService.CreateInvoiceAsync(_newInvoice);
        _showModal = false;
        await LoadInvoices();
        return result;
    }

    private void ViewInvoice(InvoiceResponse invoice)
    {
        _selectedInvoice = invoice;
        _showDetailModal = true;
    }

    private async Task MarkAsPaid(InvoiceResponse invoice)
    {
        try
        {
            await AccountingService.RecordInvoicePaymentAsync(invoice.InvoiceId, invoice.Balance);
            await LoadInvoices();
        }
        catch (Exception)
        {
            await LoadInvoices();
        }
    }

    private async Task SendInvoice(InvoiceResponse invoice)
    {
        try
        {
            await AccountingService.UpdateInvoiceStatusAsync(invoice.InvoiceId, "Sent");
            await LoadInvoices();
        }
        catch (Exception)
        {
            await LoadInvoices();
        }
    }
}