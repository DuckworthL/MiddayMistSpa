                                                        </div>
                                                        <div class="modal-footer">
                                                            <button class="btn btn-secondary" @onclick="() => _showDrawerHistoryModal = false">Close</button>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        }

@code {
    // Tab & search state
    private string _activeTab = "appointments";
    private string _searchTerm = "";
    private string _appointmentSearch = "";
    private string? _selectedCategory;
    private bool _showProductDropdown;

    // Customer
    private string _customerSearch = "";
    private bool _showCustomerDropdown;
    private CustomerResponse? _selectedCustomer;
    private List<CustomerResponse> _filteredCustomers = new();
    private List<CustomerResponse> _customers = new();

    // Loyalty (POS)
    private int _pointsToRedeem = 0;

    // Appointments
    private List<AppointmentResponse> _appointments = new();
    private AppointmentResponse? _selectedAppointment;
    private bool _appointmentsLoading;

    // Cart
    private List<CartItem> _cartItems = new();

    // Products & Services
    private List<ServiceResponse> _services = new();
    private List<ProductResponse> _products = new();

    // Payment
    private decimal _discountPercent;
    private string _paymentMethod = "Cash";
    private decimal _cashTendered;
    private bool _isProcessing;
    private bool _showSuccessModal;
    private string? _errorMessage;
    private TransactionResponse? _lastTransaction;

    // Store values at checkout time for the success modal
    private decimal _lastCashTendered;
    private decimal _lastGrandTotal;
    private string _lastPaymentMethod = "Cash";

    // Currency state
    private string _selectedCurrency = "PHP";
    private decimal _exchangeRate = 1.0m;
    private List<SupportedCurrencyInfo> _supportedCurrencies = new();
#pragma warning disable CS0414
    private bool _currencyLoading;
#pragma warning restore CS0414

    private const decimal TaxRate = 0.12m;
    private decimal Subtotal => _cartItems.Sum(x => x.Total);
    private decimal DiscountAmount => Subtotal * (_discountPercent / 100);
    private decimal PointsDiscount => _selectedCustomer != null ? Math.Min(_pointsToRedeem, _selectedCustomer.LoyaltyPoints)
    : 0;
    private decimal TaxableAmount => Subtotal - DiscountAmount - PointsDiscount;
    private decimal TaxAmount => TaxableAmount * TaxRate;
    private decimal GrandTotal => TaxableAmount + TaxAmount;
    private bool CanCheckout => _cartItems.Any() &&
    (_paymentMethod != "Cash" || _cashTendered >= GrandTotal);

    private async Task LoadData()
    {
        try
        {
            _appointmentsLoading = true;

            var productsTask = InventoryService.GetProductsAsync(1, 100);
            var customersTask = CustomerService.GetCustomersAsync(1, 200);
            var currencyTask = LoadCurrencyInfo();
            var servicesTask = ServiceService.GetServicesAsync(1, 100);
            var drawerTask = LoadDrawerSession();

            await Task.WhenAll(productsTask, customersTask, currencyTask, servicesTask, drawerTask);

            _products = (await productsTask)?.Items.Where(p => p.IsActive).ToList() ?? new();
            _customers = (await customersTask)?.Items.ToList() ?? new();
            _services = (await servicesTask)?.Items.Where(s => s.IsActive).ToList() ?? new();

            // Load active appointments (today by default)
            await LoadAppointments();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading POS data: {ex.Message}");
        }
        finally
        {
            _appointmentsLoading = false;
        }
    }

    private async Task LoadAppointments()
    {
        try
        {
            _appointmentsLoading = true;

            // Load appointments for today that are in active statuses (exclude Completed to prevent duplicate transactions)
            var result = await AppointmentService.GetAppointmentsAsync(1, 100, PhilippineTime.Today);
            if (result?.Items != null)
            {
                _appointments = result.Items
                .Where(a => a.Status is "Confirmed" or "Checked In" or "In Progress")
                .OrderBy(a => a.StartTime)
                .ToList();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading appointments: {ex.Message}");
        }
        finally
        {
            _appointmentsLoading = false;
        }
    }

    private void SwitchTab(string tab)
    {
        _activeTab = tab;
        _searchTerm = "";
        _selectedCategory = null;
    }

    // ========================================================================
    // Appointment handling
    // ========================================================================

    private IEnumerable<AppointmentResponse> GetFilteredAppointments()
    {
        var query = _appointments.AsEnumerable();

        // If a customer is selected, filter appointments for that customer
        if (_selectedCustomer != null)
        {
            query = query.Where(a => a.CustomerId == _selectedCustomer.CustomerId);
        }

        if (!string.IsNullOrWhiteSpace(_appointmentSearch))
        {
            query = query.Where(a =>
            a.CustomerName.Contains(_appointmentSearch, StringComparison.OrdinalIgnoreCase) ||
            a.AppointmentNumber.Contains(_appointmentSearch, StringComparison.OrdinalIgnoreCase) ||
            a.ServiceName.Contains(_appointmentSearch, StringComparison.OrdinalIgnoreCase));
        }

        return query;
    }

    private void SelectAppointment(AppointmentResponse appointment)
    {
        if (_selectedAppointment?.AppointmentId == appointment.AppointmentId)
        {
            // Deselect
            DeselectAppointment();
            return;
        }

        _selectedAppointment = appointment;

        // Auto-set customer from appointment
        var matchingCustomer = _customers.FirstOrDefault(c => c.CustomerId == appointment.CustomerId);
        if (matchingCustomer != null)
        {
            _selectedCustomer = matchingCustomer;
        }

        // Remove existing service items from cart (from any other appointment)
        _cartItems.RemoveAll(c => c.Type == "Service");

        // Add the appointment's services to cart
        if (appointment.ServiceItems.Any())
        {
            foreach (var si in appointment.ServiceItems)
            {
                _cartItems.Add(new CartItem
                {
                    ItemId = si.ServiceId,
                    Name = si.ServiceName,
                    Type = "Service",
                    UnitPrice = si.UnitPrice,
                    Quantity = si.Quantity
                });
            }
        }
        else
        {
            // Legacy single-service appointment
            _cartItems.Add(new CartItem
            {
                ItemId = appointment.ServiceId,
                Name = appointment.ServiceName,
                Type = "Service",
                UnitPrice = appointment.ServicePrice,
                Quantity = 1
            });
        }
    }

    private void DeselectAppointment()
    {
        _selectedAppointment = null;
        _cartItems.RemoveAll(c => c.Type == "Service");
    }

    private string GetStatusBadgeClass(string status) => status switch
    {
        "Confirmed" => "bg-info",
        "Checked In" => "bg-warning text-dark",
        "In Progress" => "bg-primary",
        "Completed" => "bg-success",
        _ => "bg-secondary"
    };

    // ========================================================================
    // Product handling
    // ========================================================================

    private IEnumerable<string> GetProductCategories()
    {
        return _products.Select(p => p.CategoryName).Distinct().Where(c => !string.IsNullOrEmpty(c))!;
    }

    private IEnumerable<ProductResponse> GetFilteredProducts()
    {
        var query = _products.AsEnumerable();
        if (!string.IsNullOrWhiteSpace(_searchTerm))
            query = query.Where(p => p.ProductName.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase));
        if (!string.IsNullOrEmpty(_selectedCategory))
            query = query.Where(p => p.CategoryName == _selectedCategory);
        return query;
    }

    private void AddProductToCart(ProductResponse product)
    {
        if (product.QuantityInStock <= 0) return;

        var existing = _cartItems.FirstOrDefault(x => x.ItemId == product.ProductId && x.Type == "Product");
        if (existing != null)
        {
            if (existing.Quantity < product.QuantityInStock)
                existing.Quantity++;
        }
        else
        {
            _cartItems.Add(new CartItem
            {
                ItemId = product.ProductId,
                Name = product.ProductName,
                Type = "Product",
                UnitPrice = product.SellingPrice ?? product.CostPrice,
                Quantity = 1
            });
        }
    }

    // ========================================================================
    // Cart management
    // ========================================================================

    private void UpdateQuantity(CartItem item, int change)
    {
        item.Quantity += change;
        if (item.Quantity <= 0)
            RemoveFromCart(item);
    }

    private void RemoveFromCart(CartItem item)
    {
        _cartItems.Remove(item);

        // If removing the last service item and there's a selected appointment, deselect it
        if (item.Type == "Service" && !_cartItems.Any(c => c.Type == "Service"))
        {
            _selectedAppointment = null;
        }
    }

    private void ClearCart()
    {
        _cartItems.Clear();
        _selectedAppointment = null;
        _discountPercent = 0;
        _cashTendered = 0;
        _pointsToRedeem = 0;
    }

    // ========================================================================
    // Customer handling
    // ========================================================================

    private void OnCustomerSearchInput(ChangeEventArgs e)
    {
        _customerSearch = e.Value?.ToString() ?? "";
        _showCustomerDropdown = true;
        FilterCustomers();
    }

    private void OnCustomerFocus()
    {
        _showCustomerDropdown = true;
        FilterCustomers();
    }

    private void FilterCustomers()
    {
        if (string.IsNullOrWhiteSpace(_customerSearch))
        {
            _filteredCustomers = _customers.Take(10).ToList();
        }
        else
        {
            _filteredCustomers = _customers
            .Where(c => c.FullName.Contains(_customerSearch, StringComparison.OrdinalIgnoreCase) ||
            (!string.IsNullOrEmpty(c.PhoneNumber) && c.PhoneNumber.Contains(_customerSearch, StringComparison.OrdinalIgnoreCase)) ||
            (!string.IsNullOrEmpty(c.Email) && c.Email.Contains(_customerSearch, StringComparison.OrdinalIgnoreCase)))
            .Take(10)
            .ToList();
        }
    }

    private void SelectCustomer(CustomerResponse customer)
    {
        _selectedCustomer = customer;
        _pointsToRedeem = 0;
        _showCustomerDropdown = false;
        _customerSearch = "";
        _filteredCustomers = new List<CustomerResponse>();
    }

    private void ClearCustomer()
    {
        _selectedCustomer = null;
        _pointsToRedeem = 0;
        if (_selectedAppointment != null)
        {
            DeselectAppointment();
        }
    }

    // ========================================================================
    // Currency
    // ========================================================================

    private async Task LoadCurrencyInfo()
    {
        try
        {
            var supported = await CurrencyService.GetSupportedCurrenciesAsync();
            if (supported?.Currencies != null)
                _supportedCurrencies = supported.Currencies;

            var detected = await CurrencyService.DetectClientAsync();
            if (detected != null && detected.IsSupported && detected.SuggestedCurrency != "PHP")
            {
                _selectedCurrency = detected.SuggestedCurrency;
                _exchangeRate = detected.ExchangeRate ?? 1.0m;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Currency detection failed: {ex.Message}");
        }
    }

    private async Task OnCurrencyChanged(ChangeEventArgs e)
    {
        _selectedCurrency = e.Value?.ToString() ?? "PHP";
        if (_selectedCurrency == "PHP")
        {
            _exchangeRate = 1.0m;
            return;
        }

        _currencyLoading = true;
        try
        {
            var rate = await CurrencyService.GetRateAsync(_selectedCurrency);
            _exchangeRate = rate?.ExchangeRate ?? 1.0m;
        }
        catch
        {
            _exchangeRate = 1.0m;
        }
        finally
        {
            _currencyLoading = false;
        }
    }

    private string ConvertDisplay(decimal phpAmount)
    {
        if (_selectedCurrency == "PHP" || _exchangeRate <= 0) return "";
        var converted = phpAmount * _exchangeRate;
        return $"\u2248 {CurrencyDisplay.GetCurrencySymbol(_selectedCurrency)}{converted:N2} {_selectedCurrency}";
    }

    // ========================================================================
    // Discount
    // ========================================================================

    private void ApplyDiscount()
    {
        if (_discountPercent < 0) _discountPercent = 0;
        if (_discountPercent > 100) _discountPercent = 100;
    }

    // ========================================================================
    // Checkout
    // ========================================================================

    private async Task ProcessCheckout()
    {
        if (!CanCheckout) return;

        _isProcessing = true;
        _errorMessage = null;

        try
        {
            var serviceItems = _cartItems
            .Where(c => c.Type == "Service")
            .Select(c => new CreateTransactionServiceItemRequest
            {
                ServiceId = c.ItemId,
                Quantity = c.Quantity,
                UnitPrice = null
            }).ToList();

            var productItems = _cartItems
            .Where(c => c.Type == "Product")
            .Select(c => new CreateTransactionProductItemRequest
            {
                ProductId = c.ItemId,
                Quantity = c.Quantity,
                UnitPrice = null
            }).ToList();

            var transaction = new CreateTransactionRequest
            {
                CustomerId = _selectedCustomer?.CustomerId,
                AppointmentId = _selectedAppointment?.AppointmentId,
                PaymentMethod = _paymentMethod,
                DiscountAmount = DiscountAmount,
                LoyaltyPointsToRedeem = _pointsToRedeem,
                ServiceItems = serviceItems,
                ProductItems = productItems,
                AmountTendered = _paymentMethod == "Cash" && _cashTendered > 0 ? _cashTendered : null,
                ClientCurrency = _selectedCurrency != "PHP" ? _selectedCurrency : null
            };

            _lastCashTendered = _cashTendered;
            _lastGrandTotal = GrandTotal;
            _lastPaymentMethod = _paymentMethod;

            _lastTransaction = await TransactionService.CreateTransactionAsync(transaction);

            if (_lastTransaction != null)
            {
                _showSuccessModal = true;
                // Refresh drawer session to update cash totals
                await LoadDrawerSession();
            }
            else
            {
                _errorMessage = "Transaction failed. Please check the details and try again.";
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Checkout error: {ex.Message}");
            _errorMessage = $"Failed to process transaction: {ex.Message}";
        }
        finally
        {
            _isProcessing = false;
        }
    }

    // ========================================================================
    // Receipt
    // ========================================================================

    private async Task PrintReceipt()
    {
        if (_lastTransaction == null) return;

        var customerName = _lastTransaction.CustomerName ?? "Walk-in";
        var appointmentInfo = _selectedAppointment != null
        ? $"<div class='item'><span>Appointment:</span><span>{_selectedAppointment.AppointmentNumber}</span></div><div class='item'><span>Therapist:</span><span>{_selectedAppointment.TherapistName ?? "N/A"}</span></div>"
        : "";

        var receipt = $@"
<html>
<head>
<title>Receipt #{_lastTransaction.TransactionNumber}</title>
<style>
body {{ font-family: 'Courier New', monospace; width: 300px; margin: 0 auto; padding: 20px; }}
.header {{ text-align: center; margin-bottom: 20px; }}
.header h2 {{ margin: 0; font-size: 18px; }}
.header p {{ margin: 5px 0; font-size: 12px; }}
.divider {{ border-top: 1px dashed #000; margin: 10px 0; }}
.item {{ display: flex; justify-content: space-between; font-size: 12px; margin: 5px 0; }}
.total {{ font-weight: bold; font-size: 14px; }}
.section-label {{ font-size: 11px; font-weight: bold; margin-top: 8px; text-transform: uppercase; color: #666; }}
.footer {{ text-align: center; margin-top: 20px; font-size: 11px; }}
</style>
</head>
<body>
<div class='header'>
<h2>MiddayMist Spa</h2>
<p>123 Wellness Street, Manila</p>
<p>Tel: (02) 8888-MIST</p>
</div>
<div class='divider'></div>
<div class='item'><span>Receipt #:</span><span>{_lastTransaction.TransactionNumber}</span></div>
<div class='item'><span>Date:</span><span>{_lastTransaction.TransactionDate:MMM dd, yyyy hh:mm tt}</span></div>
<div class='item'><span>Customer:</span><span>{customerName}</span></div>
<div class='item'><span>Cashier:</span><span>{_lastTransaction.CashierName}</span></div>
{appointmentInfo}
<div class='divider'></div>";

        if (_lastTransaction.ServiceItems.Any())
        {
            receipt += "<div class='section-label'>Services</div>";
            foreach (var item in _lastTransaction.ServiceItems)
            {
                receipt += $"<div class='item'><span>{item.ServiceName} x{item.Quantity}</span><span>₱{item.TotalPrice:N2}</span></div>";
            }
        }

        if (_lastTransaction.ProductItems.Any())
        {
            receipt += "<div class='section-label'>Products</div>";
            foreach (var item in _lastTransaction.ProductItems)
            {
                receipt += $"<div class='item'><span>{item.ProductName} x{item.Quantity}</span><span>₱{item.TotalPrice:N2}</span></div>";
            }
        }

        receipt += $@"
<div class='divider'></div>
<div class='item'><span>Subtotal:</span><span>₱{_lastTransaction.Subtotal:N2}</span></div>";

        if (_lastTransaction.DiscountAmount > 0)
        {
            receipt += $"<div class='item'><span>Discount:</span><span>-₱{_lastTransaction.DiscountAmount:N2}</span></div>";
        }

        receipt += $@"
<div class='item'><span>Tax (12%):</span><span>₱{_lastTransaction.TaxAmount:N2}</span></div>
<div class='divider'></div>
<div class='item total'><span>TOTAL:</span><span>₱{_lastTransaction.TotalAmount:N2}</span></div>";

        if (_lastTransaction.ClientCurrency != "PHP" && _lastTransaction.TotalInClientCurrency.HasValue)
        {
            receipt += $"<div class='item'><span>In {_lastTransaction.ClientCurrency}:</span><span>{CurrencyDisplay.GetCurrencySymbol(_lastTransaction.ClientCurrency)}{_lastTransaction.TotalInClientCurrency:N2}</span></div>";
        }

        receipt += $@"
<div class='item'><span>Payment:</span><span>{_lastTransaction.PaymentMethod}</span></div>
<div class='divider'></div>
<div class='footer'>
<p>Thank you for visiting MiddayMist Spa!</p>
<p>We hope to see you again soon.</p>
</div>
</body>
</html>";

        await JSRuntime.InvokeVoidAsync("printReceipt", receipt);
    }

    private void StartNewSale()
    {
        _showSuccessModal = false;
        ClearCart();
        _selectedCustomer = null;
        _lastTransaction = null;
        _ = LoadAppointments();
    }

    // ========================================================================
    // Models
    // ========================================================================

    private class CartItem
    {
        public int ItemId { get; set; }
        public string Name { get; set; } = "";
        public string Type { get; set; } = "";
        public decimal UnitPrice { get; set; }
        public int Quantity { get; set; }
        public decimal Total => UnitPrice * Quantity;
    }

    // ========================================================================
    // Cash Drawer Management
    // ========================================================================

    private CashDrawerSessionResponse? _drawerSession;
    private bool _showOpenDrawerModal;
    private bool _showCloseDrawerModal;
    private bool _showDrawerHistoryModal;
    private bool _drawerProcessing;
    private decimal _drawerFloat = 1000;
    private string? _drawerNotes;
    private decimal _drawerActualCash;
    private string? _drawerCloseNotes;
    private string? _drawerError;
    private List<CashDrawerSessionResponse> _drawerHistory = new();

    private async Task LoadDrawerSession()
    {
        try
        {
            _drawerSession = await CashDrawerService.GetActiveSessionAsync();
        }
        catch { /* Drawer service may be unavailable, proceed without it */ }
    }

    private void ShowOpenDrawerModal()
    {
        _drawerFloat = 1000;
        _drawerNotes = null;
        _drawerError = null;
        _showOpenDrawerModal = true;
    }

    private void ShowCloseDrawerModal()
    {
        _drawerActualCash = _drawerSession?.ExpectedCash ?? 0;
        _drawerCloseNotes = null;
        _drawerError = null;
        _showCloseDrawerModal = true;
    }

    private async Task ShowDrawerHistory()
    {
        _drawerHistory = await CashDrawerService.GetSessionHistoryAsync();
        _showDrawerHistoryModal = true;
    }

    private async Task OpenDrawer()
    {
        _drawerProcessing = true;
        _drawerError = null;
        try
        {
            var (result, error) = await CashDrawerService.OpenDrawerAsync(new OpenDrawerRequest
            {
                StartingFloat = _drawerFloat,
                Notes = _drawerNotes
            });
            if (error != null) { _drawerError = error; }
            else { _drawerSession = result; _showOpenDrawerModal = false; }
        }
        catch (Exception ex) { _drawerError = ex.Message; }
        _drawerProcessing = false;
    }

    private async Task CloseDrawer()
    {
        _drawerProcessing = true;
        _drawerError = null;
        try
        {
            var (result, error) = await CashDrawerService.CloseDrawerAsync(new CloseDrawerRequest
            {
                ActualCash = _drawerActualCash,
                Notes = _drawerCloseNotes
            });
            if (error != null) { _drawerError = error; }
            else { _drawerSession = null; _showCloseDrawerModal = false; }
        }
        catch (Exception ex) { _drawerError = ex.Message; }
        _drawerProcessing = false;
    }
}