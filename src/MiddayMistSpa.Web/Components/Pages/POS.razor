@page "/pos"
@inject IServiceApiService ServiceService
@inject IInventoryApiService InventoryService
@inject ICustomerApiService CustomerService
@inject ITransactionApiService TransactionService
@inject IAppointmentApiService AppointmentService
@inject ICurrencyApiService CurrencyService
@inject IRolePermissionService RolePermissionService
@inject IAuthStateService AuthService
@inject ICashDrawerApiService CashDrawerService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<PageTitle>POS - MiddayMist Spa</PageTitle>

<AuthorizedPage OnAuthReady="LoadData">
    @* Cash Drawer Status Bar *@
    <div class="d-flex align-items-center justify-content-between px-3 py-2 mb-2 rounded border bg-light">
        @if (_drawerSession != null && _drawerSession.Status == "Open")
        {
            <div class="d-flex align-items-center gap-3 flex-wrap">
                <span class="badge bg-success"><i class="bi bi-unlock me-1"></i>Drawer Open</span>
                <small class="text-muted">Opened by @_drawerSession.OpenedByName at @_drawerSession.OpenedAt.ToString("hh:mm tt")</small>
                <small><strong>Float:</strong> ₱@_drawerSession.StartingFloat.ToString("N2")</small>
                <small><strong>Cash In:</strong> ₱@_drawerSession.TotalCashIn.ToString("N2")</small>
                <small><strong>Expected:</strong> ₱@_drawerSession.ExpectedCash.ToString("N2")</small>
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-outline-info btn-sm" @onclick="ShowDrawerHistory">
                    <i class="bi bi-clock-history me-1"></i>History
                </button>
                <button class="btn btn-outline-danger btn-sm" @onclick="ShowCloseDrawerModal">
                    <i class="bi bi-lock me-1"></i>Close Drawer
                </button>
            </div>
        }
        else
        {
            <div class="d-flex align-items-center gap-2">
                <span class="badge bg-secondary"><i class="bi bi-lock me-1"></i>Drawer Closed</span>
                <small class="text-muted">Open the cash drawer to start accepting cash payments</small>
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-outline-info btn-sm" @onclick="ShowDrawerHistory">
                    <i class="bi bi-clock-history me-1"></i>History
                </button>
                <button class="btn btn-success btn-sm" @onclick="ShowOpenDrawerModal">
                    <i class="bi bi-unlock me-1"></i>Open Drawer
                </button>
            </div>
        }
    </div>

    <div class="pos-container">
        @* Left Panel - Appointments & Products *@
        <div class="pos-products">
            <div class="pos-header">
                <h4 class="mb-0">Point of Sale</h4>
                <div class="btn-group" role="group">
                    <button class="btn @(_activeTab == "appointments" ? "btn-primary" : "btn-outline-primary")"
                            @onclick='() => SwitchTab("appointments")'>
                        <i class="bi bi-calendar-check me-1"></i> Appointments
                    </button>
                    <button class="btn @(_activeTab == "products" ? "btn-primary" : "btn-outline-primary")"
                            @onclick='() => SwitchTab("products")'>
                        <i class="bi bi-box me-1"></i> Products
                    </button>
                </div>
            </div>

            @if (_activeTab == "appointments")
            {
                @* Appointment Panel *@
                <div class="pos-search mb-3">
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-search"></i></span>
                        <input type="text" class="form-control" placeholder="Search appointments by customer name..."
                               @bind="_appointmentSearch" @bind:event="oninput" />
                    </div>
                </div>

                @if (_appointmentsLoading)
                {
                    <div class="text-center py-4">
                        <div class="spinner-border text-primary" role="status"></div>
                        <p class="text-muted mt-2">Loading appointments...</p>
                    </div>
                }
                else if (!GetFilteredAppointments().Any())
                {
                    <div class="empty-cart text-center py-4">
                        <i class="bi bi-calendar-x" style="font-size: 2.5rem; opacity: 0.3;"></i>
                        <p class="text-muted mt-2">No active appointments found</p>
                        <small class="text-muted">Appointments with status Confirmed, Checked In, or In Progress will appear
                            here</small>
                        </div>
                    }
            else
                    {
                        <div class="appointment-list">
                            @foreach (var appt in GetFilteredAppointments())
                            {
                                var isSelected = _selectedAppointment?.AppointmentId == appt.AppointmentId;
                                <div class="appointment-card @(isSelected ? "selected" : "")" @onclick="() => SelectAppointment(appt)">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            <div class="fw-bold">@appt.CustomerName</div>
                                            <div class="text-muted small">@appt.AppointmentNumber</div>
                                        </div>
                                        <span class="badge @GetStatusBadgeClass(appt.Status)">@appt.Status</span>
                                    </div>
                                    <div class="mt-2">
                                        @if (appt.ServiceItems.Any())
                                        {
                                            @foreach (var si in appt.ServiceItems)
                                            {
                                                <div class="small"><i class="bi bi-gem me-1 text-primary"></i>@si.ServiceName —
                                                    ₱@si.UnitPrice.ToString("N0") (@si.DurationMinutes min)</div>
                                                }
                                            }
                        else
                                            {
                                                <div class="small"><i class="bi bi-gem me-1 text-primary"></i>@appt.ServiceName —
                                                    ₱@appt.ServicePrice.ToString("N0") (@appt.DurationMinutes min)</div>
                                                }
                                            </div>
                                            <div class="d-flex justify-content-between align-items-center mt-2 small text-muted">
                                                <span><i class="bi bi-person me-1"></i>@(appt.TherapistName ?? "Unassigned")</span>
                                                <span><i class="bi bi-clock me-1"></i>@appt.StartTime.ToString(@"hh\:mm") -
                                                    @appt.EndTime.ToString(@"hh\:mm")</span>
                                                </div>
                                                <div class="d-flex justify-content-between align-items-center mt-1">
                                                    <strong class="text-primary">₱@appt.TotalPrice.ToString("N0")</strong>
                                                    @if (isSelected)
                                                    {
                                                        <span class="badge bg-success"><i class="bi bi-check me-1"></i>Selected</span>
                                                    }
                                                    else
                                                    {
                                                        <button class="btn btn-sm btn-outline-primary" @onclick:stopPropagation="true"
                                                                @onclick="() => SelectAppointment(appt)">
                                                            <i class="bi bi-cart-plus me-1"></i>Add to Cart
                                                        </button>
                                                    }
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                            }
            else
                            {
                                @* Products Panel *@
                                <div class="pos-search mb-3" style="position: relative;">
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="bi bi-search"></i></span>
                                        <input type="text" class="form-control" placeholder="Search products by name..." @bind="_searchTerm"
                                               @bind:event="oninput" @onfocus="() => _showProductDropdown = true" />
                                        @if (!string.IsNullOrWhiteSpace(_searchTerm))
                                        {
                                            <button class="btn btn-outline-secondary" type="button"
                                                    @onclick="() => { _searchTerm = string.Empty; _showProductDropdown = false; }">
                                                <i class="bi bi-x-lg"></i>
                                            </button>
                                        }
                                    </div>
                                    @if (_showProductDropdown && !string.IsNullOrWhiteSpace(_searchTerm))
                                    {
                                        var matches = GetFilteredProducts().Take(8).ToList();
                                        @if (matches.Any())
                                        {
                                            <div class="list-group shadow-sm"
                                                 style="position: absolute; z-index: 100; width: 100%; max-height: 280px; overflow-y: auto; top: 100%;">
                                                @foreach (var product in matches)
                                                {
                                                    <button type="button"
                                                            class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-2 @(product.QuantityInStock <= 0 ? "disabled text-muted" : "")"
                                                            @onclick="() => { AddProductToCart(product); _showProductDropdown = false; }"
                                                            disabled="@(product.QuantityInStock <= 0)">
                                                        <div>
                                                            <div class="fw-medium">@product.ProductName</div>
                                                            <small class="text-muted">@(product.CategoryName ?? "Uncategorized") &middot;
                                                                @product.QuantityInStock in stock</small>
                                                            </div>
                                                            <span class="fw-semibold text-primary">₱@((product.SellingPrice ??
                                                                                            product.CostPrice).ToString("N0"))</span>
                                                            </button>
                                                        }
                                                    </div>
                                                }
                                            }
                                        </div>

                                        <div class="pos-categories mb-3">
                                            <button class="btn btn-sm @(_selectedCategory == null ? "btn-secondary" : "btn-outline-secondary")"
                                                    @onclick="() => _selectedCategory = null">
                                                All
                                            </button>
                                            @foreach (var cat in GetProductCategories())
                                            {
                                                <button class="btn btn-sm @(_selectedCategory == cat ? "btn-secondary" : "btn-outline-secondary")"
                                                        @onclick="() => _selectedCategory = cat">
                                                    @cat
                                                </button>
                                            }
                                        </div>

                                        <div class="pos-items-grid">
                                            @foreach (var product in GetFilteredProducts())
                                            {
                                                <div class="pos-item @(product.QuantityInStock <= 0 ? "out-of-stock" : "")"
                                                     @onclick="() => AddProductToCart(product)">
                                                    <div class="pos-item-name">@product.Name</div>
                                                    <div class="pos-item-price">₱@((product.SellingPrice ?? product.CostPrice).ToString("N0"))</div>
                                                    @if (_selectedCurrency != "PHP")
                                                    {
                                                        <div class="pos-item-converted">@ConvertDisplay(product.SellingPrice ?? product.CostPrice)</div>
                                                    }
                                                    <div class="pos-item-stock">
                                                        @if (product.QuantityInStock <= 0)
                                                        {
                                                            <span class="text-danger">Out of stock</span>
                                                        }
                                                        else
                                                        {
                                                            <span>@product.QuantityInStock in stock</span>
                                                        }
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>

                                @* Right Panel - Cart & Checkout *@
                                <div class="pos-cart">
                                    <div class="cart-header">
                                        <h4 class="mb-0">Current Sale</h4>
                                        @if (_cartItems.Any() || _selectedAppointment != null)
                                        {
                                            <button class="btn btn-outline-danger btn-sm" @onclick="ClearCart">
                                                <i class="bi bi-trash me-1"></i>Clear
                                            </button>
                                        }
                                    </div>

                                    @* Customer Selection *@
                                    <div class="customer-section mb-3">
                                        @if (_selectedCustomer == null)
                                        {
                                            <div class="input-group">
                                                <span class="input-group-text"><i class="bi bi-person"></i></span>
                                                <input type="text" class="form-control" placeholder="Search customer..." value="@_customerSearch"
                                                       @oninput="OnCustomerSearchInput" @onfocus="OnCustomerFocus" />
                                            </div>
                                            @if (_showCustomerDropdown && _filteredCustomers.Any())
                                            {
                                                <div class="customer-dropdown">
                                                    @foreach (var customer in _filteredCustomers.Take(5))
                                                    {
                                                        <div class="customer-option" @onclick="() => SelectCustomer(customer)">
                                                            <strong>@customer.FullName</strong>
                                                            <span class="text-muted">@customer.PhoneNumber</span>
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        }
                                        else
                                        {
                                            <div class="selected-customer">
                                                <div class="d-flex align-items-center gap-2">
                                                    <div class="customer-avatar">
                                                        <i class="bi bi-person-fill"></i>
                                                    </div>
                                                    <div>
                                                        <strong>@_selectedCustomer.FullName</strong>
                                                        <div class="small text-muted">@_selectedCustomer.PhoneNumber</div>
                                                        <div class="small">
                                                            <span class="badge bg-warning text-dark me-1">@_selectedCustomer.MembershipType</span>
                                                            <i class="bi bi-gem text-warning me-1" style="font-size:0.75rem"></i>
                                                            <span class="fw-semibold">@_selectedCustomer.LoyaltyPoints pts</span>
                                                        </div>
                                                    </div>
                                                </div>
                                                <button class="btn btn-link text-danger btn-sm" @onclick="ClearCustomer">
                                                    <i class="bi bi-x-lg"></i>
                                                </button>
                                            </div>

                                            @* Use Loyalty Points *@
                                            @if (_selectedCustomer.LoyaltyPoints > 0 && _cartItems.Any())
                                            {
                                                <div class="mt-2">
                                                    <div class="input-group input-group-sm">
                                                        <span class="input-group-text"><i class="bi bi-gem me-1"></i>Redeem pts</span>
                                                        <input type="number" class="form-control" placeholder="0" value="@_pointsToRedeem"
                                                               @oninput="e => { if (int.TryParse(e.Value?.ToString(), out int v)) _pointsToRedeem = Math.Min(Math.Max(0, v), _selectedCustomer.LoyaltyPoints); }"
                                                               min="0" max="@_selectedCustomer.LoyaltyPoints" step="1" />
                                                        <span class="input-group-text text-success">-₱@_pointsToRedeem</span>
                                                    </div>
                                                    <div class="form-text">1 pt = ₱1 &nbsp;|&nbsp; Max: @_selectedCustomer.LoyaltyPoints pts</div>
                                                </div>
                                            }
                                        }
                                    </div>

                                    @* Cart Items *@
                                    <div class="cart-items">
                                        @if (!_cartItems.Any())
                                        {
                                            <div class="empty-cart">
                                                <p class="mb-1">No items yet</p>
                                                <small class="text-muted">Select an appointment or add products</small>
                                            </div>
                                        }
                                        else
                                        {
                                            @* Service items from appointment *@
                                            @foreach (var item in _cartItems.Where(c => c.Type == "Service"))
                                            {
                                                <div class="cart-item cart-item-service">
                                                    <div class="cart-item-row-top">
                                                        <span class="cart-item-name" title="@item.Name">
                                                            <i class="bi bi-gem text-primary" style="font-size:0.7rem"></i> @item.Name
                                                        </span>
                                                        <div class="cart-item-qty">
                                                            <button class="btn btn-sm btn-outline-secondary"
                                                                    @onclick="() => UpdateQuantity(item, -1)"><i class="bi bi-dash"></i></button>
                                                            <span>@item.Quantity</span>
                                                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => UpdateQuantity(item, 1)"><i
                                                                class="bi bi-plus"></i></button>
                                                            </div>
                                                        </div>
                                                        <div class="cart-item-row-bottom">
                                                            <span class="cart-item-price">₱ @item.Total.ToString("N2")</span>
                                                            @if (_selectedCurrency != "PHP")
                                                            {
                                                                <span class="cart-item-converted">@ConvertDisplay(item.Total)</span>
                                                            }
                                                        </div>
                                                    </div>
                                                }

                                                @* Product items *@
                                                @foreach (var item in _cartItems.Where(c => c.Type == "Product"))
                                                {
                                                    <div class="cart-item">
                                                        <div class="cart-item-row-top">
                                                            <span class="cart-item-name" title="@item.Name">
                                                                <i class="bi bi-box text-secondary" style="font-size:0.7rem"></i> @item.Name
                                                            </span>
                                                            <div class="cart-item-qty">
                                                                <button class="btn btn-sm btn-outline-secondary"
                                                                        @onclick="() => UpdateQuantity(item, -1)"><i class="bi bi-dash"></i></button>
                                                                <span>@item.Quantity</span>
                                                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => UpdateQuantity(item, 1)"><i
                                                                    class="bi bi-plus"></i></button>
                                                                </div>
                                                            </div>
                                                            <div class="cart-item-row-bottom">
                                                                <span class="cart-item-price">₱ @item.Total.ToString("N2")</span>
                                                                @if (_selectedCurrency != "PHP")
                                                                {
                                                                    <span class="cart-item-converted">@ConvertDisplay(item.Total)</span>
                                                                }
                                                            </div>
                                                        </div>
                                                    }
                                                }
                                            </div>

                                            @* Discount Section *@
                                            @if (_cartItems.Any())
                                            {
                                                <div class="discount-section">
                                                    <div class="input-group input-group-sm">
                                                        <span class="input-group-text"><i class="bi bi-percent"></i></span>
                                                        <input type="number" class="form-control" placeholder="Discount %" @bind="_discountPercent" min="0"
                                                               max="100" />
                                                        <button class="btn btn-outline-secondary" type="button" @onclick="ApplyDiscount">Apply</button>
                                                    </div>
                                                </div>
                                            }

                                            @* Cart Summary *@
                                            <div class="cart-summary">
                                                <div class="summary-row">
                                                    <span>Subtotal</span>
                                                    <span>₱ @Subtotal.ToString("N2")</span>
                                                </div>
                                                <div class="summary-row">
                                                    <span>Discount (@_discountPercent%)</span>
                                                    <span class="text-danger">-₱ @DiscountAmount.ToString("N2")</span>
                                                </div>
                                                @if (PointsDiscount > 0)
                                                {
                                                    <div class="summary-row">
                                                        <span><i class="bi bi-gem me-1"></i>Points (@_pointsToRedeem pts)</span>
                                                        <span class="text-danger">-₱ @PointsDiscount.ToString("N2")</span>
                                                    </div>
                                                }
                                                <div class="summary-row">
                                                    <span>VAT (12%)</span>
                                                    <span>₱ @TaxAmount.ToString("N2")</span>
                                                </div>
                                                <div class="summary-row total">
                                                    <span>Total</span>
                                                    <span>
                                                        ₱ @GrandTotal.ToString("N2")
                                                        @if (_selectedCurrency != "PHP" && _exchangeRate > 0)
                                                        {
                                                            <small class="d-block text-muted fw-normal"
                                                                   style="font-size: 0.7em;">@ConvertDisplay(GrandTotal)</small>
                                                        }
                                                    </span>
                                                </div>
                                            </div>

                                            @* Currency Selector *@
                                            <div class="currency-section">
                                                <div class="currency-selector-inline">
                                                    <i class="bi bi-currency-exchange me-2 text-muted"></i>
                                                    <label class="form-label mb-0 me-2 small text-muted">Display Currency</label>
                                                    <select class="form-select form-select-sm currency-select-inline" value="@_selectedCurrency"
                                                            @onchange="OnCurrencyChanged">
                                                        <option value="PHP">PHP ₱</option>
                                                        @foreach (var c in _supportedCurrencies.Where(c => c.Code != "PHP"))
                                                        {
                                                            <option value="@c.Code">@c.Code @c.Symbol</option>
                                                        }
                                                    </select>
                                                </div>
                                            </div>

                                            @* Payment Methods *@
                                            <div class="payment-section">
                                                <label class="form-label">Payment Method</label>
                                                <div class="payment-methods">
                                                    <button class="payment-method @(_paymentMethod == "Cash" ? "active" : "")"
                                                            @onclick='() => _paymentMethod = "Cash"'>
                                                        <i class="bi bi-cash-coin"></i>
                                                        <span>Cash</span>
                                                    </button>
                                                    <button class="payment-method @(_paymentMethod == "Card" ? "active" : "")"
                                                            @onclick='() => _paymentMethod = "Card"'>
                                                        <i class="bi bi-credit-card"></i>
                                                        <span>Card</span>
                                                    </button>
                                                    <button class="payment-method @(_paymentMethod == "GCash" ? "active" : "")"
                                                            @onclick='() => _paymentMethod = "GCash"'>
                                                        <i class="bi bi-phone"></i>
                                                        <span>GCash</span>
                                                    </button>
                                                    <button class="payment-method @(_paymentMethod == "Bank Transfer" ? "active" : "")"
                                                            @onclick='() => _paymentMethod = "Bank Transfer"'>
                                                        <i class="bi bi-bank"></i>
                                                        <span>Bank Transfer</span>
                                                    </button>
                                                    <button class="payment-method @(_paymentMethod == "Maya" ? "active" : "")"
                                                            @onclick='() => _paymentMethod = "Maya"'>
                                                        <i class="bi bi-phone"></i>
                                                        <span>Maya</span>
                                                    </button>
                                                    <button class="payment-method @(_paymentMethod == "Split" ? "active" : "")"
                                                            @onclick='() => _paymentMethod = "Split"'>
                                                        <i class="bi bi-pie-chart"></i>
                                                        <span>Split</span>
                                                    </button>
                                                </div>
                                            </div>

                                            @* Cash Tendered (for cash payments) *@
                                            @if (_paymentMethod == "Cash")
                                            {
                                                <div class="cash-section">
                                                    <label class="form-label">Cash Tendered</label>
                                                    <div class="input-group">
                                                        <span class="input-group-text">₱</span>
                                                        <input type="number" class="form-control form-control-lg" @bind="_cashTendered" />
                                                    </div>
                                                    @if (_cashTendered > 0 && _cashTendered >= GrandTotal)
                                                    {
                                                        <div class="change-display">
                                                            <span>Change:</span>
                                                            <strong>₱@((_cashTendered - GrandTotal).ToString("N0"))</strong>
                                                        </div>
                                                    }
                                                    <div class="quick-cash">
                                                        @foreach (var amount in new[] { 100, 500, 1000, 2000, 5000 })
                                                        {
                                                            <button class="btn btn-outline-secondary btn-sm" @onclick="() => _cashTendered = amount">
                                                                ₱@amount
                                                            </button>
                                                        }
                                                        <button class="btn btn-outline-primary btn-sm" @onclick="() => _cashTendered = GrandTotal">
                                                            Exact
                                                        </button>
                                                    </div>
                                                </div>
                                            }

                                            @* Error Message *@
                                            @if (!string.IsNullOrEmpty(_errorMessage))
                                            {
                                                <div class="alert alert-danger alert-dismissible fade show mb-2" role="alert">
                                                    <i class="bi bi-exclamation-triangle me-1"></i> @_errorMessage
                                                    <button type="button" class="btn-close" @onclick="() => _errorMessage = null"></button>
                                                </div>
                                            }

                                            @* Checkout Button *@
                                            <button class="btn btn-success btn-lg w-100 checkout-btn" disabled="@(!CanCheckout)"
                                                    @onclick="ProcessCheckout">
                                                @if (_isProcessing)
                                                {
                                                    <span class="spinner-border spinner-border-sm me-2"></span>
                                                    <span>Processing...</span>
                                                }
                                                else
                                                {
                                                    <i class="bi bi-check-circle me-2"></i>
                                                    <span>Complete Sale - ₱@GrandTotal.ToString("N0")
                                                        @if (_selectedCurrency != "PHP")
                                                        {
                                                            <small class="ms-1">(@ConvertDisplay(GrandTotal))</small>
                                                        }
                                                    </span>
                                                }
                                            </button>
                                        </div>
                                    </div>

                                    @* Success Modal *@
                                    @if (_showSuccessModal)
                                    {
                                        <div class="modal-backdrop fade show"></div>
                                        <div class="modal fade show d-block" tabindex="-1">
                                            <div class="modal-dialog modal-dialog-centered">
                                                <div class="modal-content">
                                                    <div class="modal-body text-center py-5">
                                                        <div class="success-icon mb-4">
                                                            <i class="bi bi-check-circle-fill"></i>
                                                        </div>
                                                        <h3 class="text-success mb-2">Payment Successful!</h3>
                                                        <p class="text-muted mb-4">Transaction completed successfully</p>
                                                        <div class="receipt-summary">
                                                            <div class="d-flex justify-content-between mb-2">
                                                                <span>Total Paid:</span>
                                                                <strong>₱@(_lastPaymentMethod == "Cash" ? _lastCashTendered.ToString("N0") :
                                                                                                    _lastGrandTotal.ToString("N0"))</strong>
                                                                </div>
                                                                @if (_lastTransaction?.ClientCurrency != null && _lastTransaction.ClientCurrency != "PHP" &&
                                                                                        _lastTransaction.TotalInClientCurrency.HasValue)
                                                                {
                                                                    <div class="d-flex justify-content-between mb-2">
                                                                        <span>In @_lastTransaction.ClientCurrency:</span>
                                                                        <strong>@CurrencyDisplay.GetCurrencySymbol(_lastTransaction.ClientCurrency)@_lastTransaction.TotalInClientCurrency?.ToString("N2")</strong>
                                                                    </div>
                                                                }
                                                                @if (_lastPaymentMethod == "Cash" && _lastCashTendered > _lastGrandTotal)
                                                                {
                                                                    <div class="d-flex justify-content-between mb-2">
                                                                        <span>Change:</span>
