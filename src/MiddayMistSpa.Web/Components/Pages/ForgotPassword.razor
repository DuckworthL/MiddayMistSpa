@page "/forgot-password"
@layout EmptyLayout
@inject NavigationManager Navigation
@inject IApiClient ApiClient

<PageTitle>Forgot Password - MiddayMist Spa</PageTitle>

<div class="forgot-password-page">
    <div class="forgot-password-container">
        <div class="forgot-password-card">
            @if (!_emailSent)
            {
                <!-- Request Reset Form -->
                <div class="card-icon">
                    <i class="bi bi-key"></i>
                </div>
                <h2 class="card-title">Forgot Password?</h2>
                <p class="card-subtitle">No worries! Enter your email and we'll send you reset instructions.</p>

                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <div class="alert alert-danger d-flex align-items-center" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        <div>@_errorMessage</div>
                    </div>
                }

                <EditForm Model="_model" OnValidSubmit="HandleSubmit" FormName="forgotPassword">
                    <DataAnnotationsValidator />

                    <div class="form-floating mb-3">
                        <InputText @bind-Value="_model.Email" class="form-control" id="email"
                                   placeholder="name@example.com" />
                        <label for="email"><i class="bi bi-envelope me-2"></i>Email Address</label>
                        <ValidationMessage For="@(() => _model.Email)" />
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-3" disabled="@_isLoading">
                        @if (_isLoading)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                            <span>Sending...</span>
                        }
                        else
                        {
                            <i class="bi bi-send me-2"></i>
                            <span>Send Reset Link</span>
                        }
                    </button>
                </EditForm>
            }
            else
            {
                <!-- Success Message -->
                <div class="card-icon success">
                    <i class="bi bi-envelope-check"></i>
                </div>
                <h2 class="card-title">Check Your Email</h2>
                <p class="card-subtitle">
                    A password reset code has been generated for<br>
                    <strong>@_model.Email</strong>
                </p>

                <div class="alert alert-info d-flex align-items-start" role="alert">
                    <i class="bi bi-info-circle me-2 mt-1"></i>
                    <div>
                        <strong>Next step:</strong><br>
                        Please contact your administrator to obtain the reset code, then
                        <a href="/reset-password?email=@Uri.EscapeDataString(_model.Email)">click here to reset your
                            password</a>.
                        </div>
                    </div>

                    <button class="btn btn-outline-primary w-100 py-3" @onclick="GoToLogin">
                        <i class="bi bi-arrow-left me-2"></i>
                        Back to Login
                    </button>
                }

                <div class="back-to-login mt-4">
                    <a href="/login" class="text-muted">
                        <i class="bi bi-arrow-left me-1"></i> Back to Login
                    </a>
                </div>
            </div>
        </div>
    </div>

    <style>
        .forgot-password-page {
            min-height: 100vh;
            background: linear-gradient(135deg, #F8FAF8 0%, #E8EFE8 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1rem;
        }

        .forgot-password-container {
            width: 100%;
            max-width: 450px;
        }

        .forgot-password-card {
            background: white;
            border-radius: 1.5rem;
            padding: 2.5rem;
            border: 1px solid #E5E7EB;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.06);
            text-align: center;
        }

        .card-icon {
            width: 80px;
            height: 80px;
            background: linear-gradient(135deg, #3D5A4F 0%, #2A3F36 100%);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.5rem;
            font-size: 2rem;
            color: white;
        }

        .card-icon.success {
            background: linear-gradient(135deg, #059669 0%, #047857 100%);
        }

        .card-title {
            font-size: 1.75rem;
            font-weight: 700;
            color: #2C2C2C;
            margin-bottom: 0.75rem;
        }

        .card-subtitle {
            color: #6B7280;
            margin-bottom: 2rem;
            font-size: 0.9375rem;
            line-height: 1.5;
        }

        .form-floating>.form-control {
            padding-left: 1rem;
            height: 3.5rem;
        }

        .form-floating>label {
            padding-left: 1rem;
        }

        .btn-primary {
            background: linear-gradient(135deg, #3D5A4F 0%, #2A3F36 100%);
            border: none;
            font-weight: 600;
        }

        .btn-primary:hover {
            background: linear-gradient(135deg, #2A3F36 0%, #1F2E28 100%);
        }

        .alert-info {
            background: #EFF6FF;
            border: none;
            color: #1E40AF;
            text-align: left;
            border-radius: 0.75rem;
        }

        .alert-info a {
            color: #1E40AF;
            font-weight: 600;
        }

        .back-to-login {
            margin-top: 1.5rem;
        }

        .back-to-login a {
            text-decoration: none;
            font-size: 0.875rem;
        }

        .back-to-login a:hover {
            color: #3D5A4F !important;
        }
    </style>

@code {
    private ForgotPasswordModel _model = new();
    private bool _isLoading;
    private bool _emailSent;
    private string? _errorMessage;

    private async Task HandleSubmit()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            var result = await ApiClient.PostAsync<object, PasswordResetResponse>(
                "api/auth/forgot-password", new { Email = _model.Email });

            if (result?.Success == true)
            {
                _emailSent = true;
            }
            else
            {
                _errorMessage = result?.Message ?? "An error occurred. Please try again later.";
            }
        }
        catch (Exception)
        {
            _errorMessage = "An error occurred. Please try again later.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task ResendEmail()
    {
        _isLoading = true;
        try
        {
            await ApiClient.PostAsync<object, PasswordResetResponse>(
                "api/auth/forgot-password", new { Email = _model.Email });
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void GoToLogin()
    {
        Navigation.NavigateTo("/login");
    }

    public class ForgotPasswordModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Email is required")]
        [System.ComponentModel.DataAnnotations.EmailAddress(ErrorMessage = "Please enter a valid email address")]
        public string Email { get; set; } = string.Empty;
    }
}