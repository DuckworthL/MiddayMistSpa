@* Roles & Permissions Settings Component *@
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-shield-lock me-2"></i>Roles & Permissions</h5>
        <button class="btn btn-primary btn-sm" @onclick="ShowAddRoleModal">
            <i class="bi bi-plus-lg me-1"></i> Add Role
        </button>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-4">
                <div class="list-group">
                    @foreach (var role in _roles)
                    {
                        <button type="button"
                                class="list-group-item list-group-item-action d-flex justify-content-between align-items-center @(_selectedRole?.Id == role.Id ? "active" : "")"
                                @onclick="() => SelectRole(role)">
                            <div>
                                <i class="bi @role.Icon me-2"></i>
                                @role.Name
                            </div>
                            <span class="badge bg-secondary">@role.UserCount users</span>
                        </button>
                    }
                </div>
            </div>
            <div class="col-md-8">
                @if (_selectedRole != null)
                {
                    <div class="card">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <h6 class="mb-0">@_selectedRole.Name Permissions</h6>
                            @if (!_selectedRole.IsSystem)
                            {
                                <button class="btn btn-outline-danger btn-sm" @onclick="DeleteRole">
                                    <i class="bi bi-trash"></i> Delete Role
                                </button>
                            }
                        </div>
                        <div class="card-body">
                            @if (_selectedRole.IsSystem)
                            {
                                <div class="alert alert-info py-2">
                                    <i class="bi bi-info-circle me-1"></i>
                                    This is a system role. Some permissions cannot be modified.
                                </div>
                            }

                            @foreach (var module in _permissionModules)
                            {
                                <div class="mb-4">
                                    <h6 class="text-muted mb-2">@module.Name</h6>
                                    <div class="row g-2">
                                        @foreach (var permission in module.Permissions)
                                        {
                                            var permKey = $"{module.Key}.{permission.Key}";
                                            var hasPermission = _selectedRole.Permissions.Contains(permKey);
                                            <div class="col-md-6">
                                                <div class="form-check">
                                                    <input type="checkbox" class="form-check-input" id="@permKey"
                                                           checked="@hasPermission"
                                                           disabled="@(_selectedRole.IsSystem && _selectedRole.Name == "SuperAdmin")"
                                                           @onchange="() => TogglePermission(permKey)" />
                                                    <label class="form-check-label" for="@permKey">
                                                        @permission.Name
                                                    </label>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }

                            <div class="d-flex gap-2 mt-4">
                                <button class="btn btn-primary" @onclick="SavePermissions">
                                    <i class="bi bi-check-lg me-1"></i> Save Permissions
                                </button>
                                <button class="btn btn-outline-secondary" @onclick="ResetPermissions">
                                    Reset
                                </button>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="text-center text-muted py-5">
                        <i class="bi bi-shield display-4"></i>
                        <p class="mt-2">Select a role to view and edit permissions</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@* Add Role Modal *@
@if (_showModal)
{
    <div class="modal show d-block" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Add New Role</h5>
                    <button type="button" class="btn-close" @onclick="() => _showModal = false"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Role Name</label>
                        <input type="text" class="form-control" @bind="_newRoleName" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea class="form-control" rows="2" @bind="_newRoleDescription"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Copy Permissions From</label>
                        <select class="form-select" @bind="_copyFromRoleId">
                            <option value="0">-- Start with no permissions --</option>
                            @foreach (var role in _roles)
                            {
                                <option value="@role.Id">@role.Name</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => _showModal = false">Cancel</button>
                    <button class="btn btn-primary" @onclick="AddRole">Add Role</button>
                </div>
            </div>
        </div>
    </div>
}

