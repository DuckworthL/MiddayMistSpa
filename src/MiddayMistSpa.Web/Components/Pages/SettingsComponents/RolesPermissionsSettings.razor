    private RoleModel? _selectedRole = null;
    private bool _showModal = false;
    private string _newRoleName = "";
    private string _newRoleDescription = "";
    private int _copyFromRoleId = 0;

    private void SelectRole(RoleModel role)
    {
        _selectedRole = role;
    }

    private void TogglePermission(string permKey)
    {
        if (_selectedRole == null) return;
        if (_selectedRole.Permissions.Contains(permKey))
            _selectedRole.Permissions.Remove(permKey);
        else
            _selectedRole.Permissions.Add(permKey);
    }

    private void SavePermissions()
    {
        // TODO: Save to API
    }

    private void ResetPermissions()
    {
        // TODO: Reset to original
    }

    private void ShowAddRoleModal()
    {
        _newRoleName = "";
        _newRoleDescription = "";
        _copyFromRoleId = 0;
        _showModal = true;
    }

    private void AddRole()
    {
        var newRole = new RoleModel
        {
            Id = _roles.Max(r => r.Id) + 1,
            Name = _newRoleName,
            Icon = "bi-person",
            IsSystem = false,
            UserCount = 0,
            Permissions = _copyFromRoleId > 0
        ? new HashSet<string>(_roles.First(r => r.Id == _copyFromRoleId).Permissions)
        : new HashSet<string>()
        };
        _roles.Add(newRole);
        _showModal = false;
        _selectedRole = newRole;
    }

    private void DeleteRole()
    {
        if (_selectedRole != null && !_selectedRole.IsSystem)
        {
            _roles.Remove(_selectedRole);
            _selectedRole = null;
        }
    }

    private class RoleModel
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public string Icon { get; set; } = "bi-person";
        public bool IsSystem { get; set; }
        public int UserCount { get; set; }
        public HashSet<string> Permissions { get; set; } = new();
    }

    private class PermissionModule
    {
        public string Key { get; set; } = "";
        public string Name { get; set; } = "";
        public List<Permission> Permissions { get; set; } = new();
    }

    private record Permission(string Key, string Name);
