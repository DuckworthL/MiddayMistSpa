            Role = "Admin", Status = "Active", LastLogin = DateTime.Now.AddHours(-2) },
        new() { Id = 3, FirstName = "Maria", LastName = "Santos", Username = "maria.santos", Email = "maria@middaymistspa.com",
            Role = "Receptionist", Status = "Active", LastLogin = DateTime.Now.AddHours(-5) },
        new() { Id = 4, FirstName = "Ana", LastName = "Reyes", Username = "ana.reyes", Email = "ana@middaymistspa.com",
            Role = "Therapist", Status = "Active", LastLogin = DateTime.Now.AddDays(-1) },
        new() { Id = 5, FirstName = "Rosa", LastName = "Cruz", Username = "rosa.cruz", Email = "rosa@middaymistspa.com",
            Role = "HR", Status = "Active", LastLogin = DateTime.Now.AddDays(-1) },
        new() { Id = 6, FirstName = "Juan", LastName = "Dela Cruz", Username = "juan.delacruz", Email =
"juan@middaymistspa.com",
            Role = "Inventory", Status = "Active", LastLogin = DateTime.Now.AddDays(-2) },
        new() { Id = 7, FirstName = "Sofia", LastName = "Garcia", Username = "sofia.garcia", Email = "sofia@middaymistspa.com",
            Role = "Accountant", Status = "Active", LastLogin = DateTime.Now.AddDays(-1) }
    };

    private string _searchTerm = "";
    private string _roleFilter = "";
    private string _statusFilter = "";
    private bool _showModal = false;
    private UserModel? _editingUser = null;
    private UserModel _formModel = new();

    private IEnumerable<UserModel> FilteredUsers => _users.Where(u =>
    (string.IsNullOrEmpty(_searchTerm) ||
    u.FirstName.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ||
    u.LastName.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ||
    u.Email.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase)) &&
    (string.IsNullOrEmpty(_roleFilter) || u.Role == _roleFilter) &&
    (string.IsNullOrEmpty(_statusFilter) || u.Status == _statusFilter)
    );

    private string GetRoleBadgeClass(string role) => role switch
    {
        "SuperAdmin" => "bg-danger",
        "Admin" => "bg-primary",
        "Receptionist" => "bg-info",
        "Therapist" => "bg-success",
        "HR" => "bg-warning text-dark",
        "Inventory" => "bg-secondary",
        "Accountant" => "bg-dark",
        _ => "bg-secondary"
    };

    private string GetStatusBadgeClass(string status) => status switch
    {
        "Active" => "bg-success",
        "Inactive" => "bg-secondary",
        "Pending" => "bg-warning text-dark",
        _ => "bg-secondary"
    };

    private void ShowAddModal()
    {
        _editingUser = null;
        _formModel = new UserModel { Role = "Therapist" };
        _showModal = true;
    }

    private void EditUser(UserModel user)
    {
        _editingUser = user;
        _formModel = new UserModel
        {
            Id = user.Id,
            FirstName = user.FirstName,
            LastName = user.LastName,
            Username = user.Username,
            Email = user.Email,
            Role = user.Role,
            Phone = user.Phone
        };
        _showModal = true;
    }

    private void CloseModal()
    {
        _showModal = false;
        _editingUser = null;
    }

    private void SaveUser()
    {
        if (_editingUser != null)
        {
            _editingUser.FirstName = _formModel.FirstName;
            _editingUser.LastName = _formModel.LastName;
            _editingUser.Email = _formModel.Email;
            _editingUser.Role = _formModel.Role;
            _editingUser.Phone = _formModel.Phone;
        }
        else
        {
            _formModel.Id = _users.Any() ? _users.Max(u => u.Id) + 1 : 1;
            _formModel.Status = "Pending";
            _users.Add(_formModel);
        }
        CloseModal();
    }

    private void ResetPassword(UserModel user)
    {
        // TODO: Implement password reset via API
    }

    private void ToggleStatus(UserModel user)
    {
        user.Status = user.Status == "Active" ? "Inactive" : "Active";
    }

    private class UserModel
    {
        public int Id { get; set; }
        public string FirstName { get; set; } = "";
        public string LastName { get; set; } = "";
        public string Username { get; set; } = "";
        public string Email { get; set; } = "";
        public string Role { get; set; } = "";
        public string Status { get; set; } = "Active";
        public string Phone { get; set; } = "";
        public string Password { get; set; } = "";
        public string ConfirmPassword { get; set; } = "";
        public DateTime? LastLogin { get; set; }
    }
}