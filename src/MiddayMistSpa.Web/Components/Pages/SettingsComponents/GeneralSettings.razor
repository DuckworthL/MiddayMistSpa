@* General Settings Component *@
<div class="card">
    <div class="card-header">
        <h5 class="mb-0"><i class="bi bi-gear me-2"></i>General Settings</h5>
    </div>
    <div class="card-body">
        <div class="row g-4">
            <div class="col-md-6">
                <div class="mb-3">
                    <label class="form-label">Application Name</label>
                    <input type="text" class="form-control" @bind="_settings.AppName" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Currency</label>
                    <select class="form-select" @bind="_settings.Currency">
                        <option value="PHP">Philippine Peso (₱)</option>
                        <option value="USD">US Dollar ($)</option>
                        <option value="EUR">Euro (€)</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">Date Format</label>
                    <select class="form-select" @bind="_settings.DateFormat">
                        <option value="MM/dd/yyyy">MM/DD/YYYY</option>
                        <option value="dd/MM/yyyy">DD/MM/YYYY</option>
                        <option value="yyyy-MM-dd">YYYY-MM-DD</option>
                    </select>
                </div>
            </div>
            <div class="col-md-6">
                <div class="mb-3">
                    <label class="form-label">Time Format</label>
                    <select class="form-select" @bind="_settings.TimeFormat">
                        <option value="12">12-hour (AM/PM)</option>
                        <option value="24">24-hour</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">Timezone</label>
                    <select class="form-select" @bind="_settings.Timezone">
                        <option value="Asia/Manila">Asia/Manila (GMT+8)</option>
                        <option value="America/New_York">America/New_York (EST)</option>
                        <option value="Europe/London">Europe/London (GMT)</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">Language</label>
                    <select class="form-select" @bind="_settings.Language">
                        <option value="en">English</option>
                        <option value="fil">Filipino</option>
                    </select>
                </div>
            </div>
        </div>

        <hr class="my-4" />

        <h6 class="mb-3">Appointment Settings</h6>
        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label">Default Appointment Duration (minutes)</label>
                <input type="number" class="form-control" @bind="_settings.DefaultDuration" min="15" step="15" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Booking Lead Time (hours)</label>
                <input type="number" class="form-control" @bind="_settings.BookingLeadTime" min="0" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Cancellation Window (hours)</label>
                <input type="number" class="form-control" @bind="_settings.CancellationWindow" min="0" />
            </div>
        </div>

        <div class="mt-4">
            <div class="form-check form-switch mb-2">
                <input class="form-check-input" type="checkbox" id="allowOnlineBooking"
                    @bind="_settings.AllowOnlineBooking">
                <label class="form-check-label" for="allowOnlineBooking">Allow online booking</label>
            </div>
            <div class="form-check form-switch mb-2">
                <input class="form-check-input" type="checkbox" id="requireDeposit" @bind="_settings.RequireDeposit">
                <label class="form-check-label" for="requireDeposit">Require deposit for appointments</label>
            </div>
            <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" id="sendReminders" @bind="_settings.SendReminders">
                <label class="form-check-label" for="sendReminders">Send appointment reminders</label>
            </div>
        </div>

        <div class="d-flex gap-2 mt-4">
            <button class="btn btn-primary" @onclick="SaveSettings">
                <i class="bi bi-check-lg me-1"></i> Save Changes
            </button>
            <button class="btn btn-outline-secondary" @onclick="ResetSettings">
                <i class="bi bi-arrow-counterclockwise me-1"></i> Reset
            </button>
        </div>
    </div>
</div>

@code {
    private GeneralSettingsModel _settings = new();

    private void SaveSettings()
    {
        // TODO: Save to API
    }

    private void ResetSettings()
    {
        _settings = new();
    }

    private class GeneralSettingsModel
    {
        public string AppName { get; set; } = "MiddayMist Spa";
        public string Currency { get; set; } = "PHP";
        public string DateFormat { get; set; } = "MM/dd/yyyy";
        public string TimeFormat { get; set; } = "12";
        public string Timezone { get; set; } = "Asia/Manila";
        public string Language { get; set; } = "en";
        public int DefaultDuration { get; set; } = 60;
        public int BookingLeadTime { get; set; } = 24;
        public int CancellationWindow { get; set; } = 48;
        public bool AllowOnlineBooking { get; set; } = true;
        public bool RequireDeposit { get; set; } = false;
        public bool SendReminders { get; set; } = true;
    }
}