@* API Services Settings Component *@
@inject ICurrencyApiService CurrencyApi

<div class="card">
    <div class="card-header">
        <h5 class="mb-0"><i class="bi bi-hdd-network me-2"></i>API Services</h5>
    </div>
    <div class="card-body">
        <p class="text-muted mb-4">External API integrations used by the system for currency detection and exchange rates. No API keys required.</p>

        @if (_isLoading)
        {
            <div class="text-center py-5">
                <div class="spinner-border text-primary" role="status"></div>
                <p class="text-muted mt-2">Checking API status...</p>
            </div>
        }
        else
        {
            <div class="row g-4">
                @* IpWhoIs - IP Geolocation *@
                <div class="col-md-6">
                    <div class="card border @(_ipWhoIsStatus.IsOnline ? "border-success" : "border-danger") h-100">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <div class="d-flex align-items-center gap-2">
                                <i class="bi bi-geo-alt-fill fs-5 text-info"></i>
                                <h6 class="mb-0">IpWhoIs</h6>
                            </div>
                            @if (_ipWhoIsStatus.IsOnline)
                            {
                                <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Online</span>
                            }
                            else
                            {
                                <span class="badge bg-danger"><i class="bi bi-x-circle me-1"></i>Offline</span>
                            }
                        </div>
                        <div class="card-body">
                            <p class="text-muted small">IP geolocation service — automatically detects visitor's country and local currency. No API key required.</p>

                            <div class="mb-3">
                                <label class="form-label text-muted small">Base URL</label>
                                <div class="fw-medium font-monospace small">https://ipwhois.app</div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label text-muted small">Purpose</label>
                                <div class="small">Auto-detect client currency for multi-currency support</div>
                            </div>

                            @if (_ipWhoIsStatus.IsOnline && _detectedInfo != null)
                            {
                                <div class="mb-3">
                                    <label class="form-label text-muted small">Last Detection</label>
                                    <div class="small">
                                        <span class="badge bg-light text-dark me-1">
                                            <i class="bi bi-flag me-1"></i>@_detectedInfo.CountryName (@_detectedInfo.CountryCode)
                                        </span>
                                        <span class="badge bg-light text-dark">
                                            <i class="bi bi-currency-exchange me-1"></i>@_detectedInfo.DetectedCurrency
                                        </span>
                                    </div>
                                </div>
                            }

                            <div class="mb-3">
                                <label class="form-label text-muted small">Rate Limit</label>
                                <div class="small text-muted">10,000 requests/month (free tier)</div>
                            </div>

                            <button class="btn btn-outline-primary btn-sm" @onclick="TestIpWhoIs" disabled="@_isTestingIp">
                                @if (_isTestingIp)
                                {
                                    <span class="spinner-border spinner-border-sm me-1"></span>
                                }
                                <i class="bi bi-arrow-repeat me-1"></i> Test Connection
                            </button>
                        </div>
                    </div>
                </div>

                @* Frankfurter - Exchange Rates *@
                <div class="col-md-6">
                    <div class="card border @(_frankfurterStatus.IsOnline ? "border-success" : "border-danger") h-100">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <div class="d-flex align-items-center gap-2">
                                <i class="bi bi-currency-exchange fs-5 text-success"></i>
                                <h6 class="mb-0">Frankfurter</h6>
                            </div>
                            @if (_frankfurterStatus.IsOnline)
                            {
                                <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Online</span>
                            }
                            else
                            {
                                <span class="badge bg-danger"><i class="bi bi-x-circle me-1"></i>Offline</span>
                            }
                        </div>
                        <div class="card-body">
                            <p class="text-muted small">European Central Bank exchange rates — provides real-time currency conversion. No API key required.</p>

                            <div class="mb-3">
                                <label class="form-label text-muted small">Base URL</label>
                                <div class="fw-medium font-monospace small">https://api.frankfurter.dev</div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label text-muted small">Base Currency</label>
                                <div class="small"><span class="badge bg-primary">PHP</span> Philippine Peso</div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label text-muted small">Auto-Refresh Interval</label>
                                <div class="small">Every 30 minutes (background service)</div>
                            </div>

                            @if (_frankfurterStatus.IsOnline && _ratesInfo != null)
                            {
                                <div class="mb-3">
                                    <label class="form-label text-muted small">Last Updated</label>
                                    <div class="small text-success">
                                        <i class="bi bi-check-circle me-1"></i>@_ratesInfo.LastUpdated.ToString("MMM dd, yyyy HH:mm")
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label text-muted small">Active Rates (@_ratesInfo.Rates.Count currencies)</label>
                                    <div class="d-flex flex-wrap gap-1">
                                        @foreach (var rate in _ratesInfo.Rates)
                                        {
                                            <span class="badge @(rate.IsStale ? "bg-warning text-dark" : "bg-light text-dark") border"
                                                  title="1 PHP = @rate.ExchangeRate.ToString("F6") @rate.TargetCurrency">
                                                @rate.TargetCurrency
                                            </span>
                                        }
                                    </div>
                                </div>
                            }

                            <button class="btn btn-outline-primary btn-sm" @onclick="TestFrankfurter" disabled="@_isTestingFrankfurter">
                                @if (_isTestingFrankfurter)
                                {
                                    <span class="spinner-border spinner-border-sm me-1"></span>
                                }
                                <i class="bi bi-arrow-repeat me-1"></i> Test & Refresh Rates
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            @* Status Summary *@
            <div class="card mt-4">
                <div class="card-header bg-light">
                    <h6 class="mb-0"><i class="bi bi-info-circle me-2"></i>Service Information</h6>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-sm mb-0">
                            <thead>
                                <tr>
                                    <th>Service</th>
                                    <th>Status</th>
                                    <th>Authentication</th>
                                    <th>Used For</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td><i class="bi bi-geo-alt-fill text-info me-1"></i> IpWhoIs</td>
                                    <td>
                                        @if (_ipWhoIsStatus.IsOnline)
                                        {
                                            <span class="text-success"><i class="bi bi-circle-fill me-1" style="font-size: 0.5rem;"></i>Operational</span>
                                        }
                                        else
                                        {
                                            <span class="text-danger"><i class="bi bi-circle-fill me-1" style="font-size: 0.5rem;"></i>Unavailable</span>
                                        }
                                    </td>
                                    <td><span class="badge bg-success">None required</span></td>
                                    <td>IP geolocation, currency detection</td>
                                </tr>
                                <tr>
                                    <td><i class="bi bi-currency-exchange text-success me-1"></i> Frankfurter (ECB)</td>
                                    <td>
                                        @if (_frankfurterStatus.IsOnline)
                                        {
                                            <span class="text-success"><i class="bi bi-circle-fill me-1" style="font-size: 0.5rem;"></i>Operational</span>
                                        }
                                        else
                                        {
                                            <span class="text-danger"><i class="bi bi-circle-fill me-1" style="font-size: 0.5rem;"></i>Unavailable</span>
                                        }
                                    </td>
                                    <td><span class="badge bg-success">None required</span></td>
                                    <td>Exchange rates, currency conversion</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(_statusMessage))
            {
                <div class="alert @_statusAlertClass mt-3 alert-dismissible fade show" role="alert">
                    <i class="bi @_statusIcon me-1"></i> @_statusMessage
                    <button type="button" class="btn-close" @onclick="() => _statusMessage = string.Empty"></button>
                </div>
            }
        }
    </div>
</div>

@code {
    private bool _isLoading = true;
    private bool _isTestingIp = false;
    private bool _isTestingFrankfurter = false;
    private string _statusMessage = string.Empty;
    private string _statusAlertClass = "alert-info";
    private string _statusIcon = "bi-info-circle";

    private ApiStatus _ipWhoIsStatus = new();
    private ApiStatus _frankfurterStatus = new();
    private DetectedClientInfoResponse? _detectedInfo;
    private AllRatesResponse? _ratesInfo;

    protected override async Task OnInitializedAsync()
    {
        await CheckServicesAsync();
    }

    private async Task CheckServicesAsync()
    {
        _isLoading = true;
        StateHasChanged();

        try
        {
            // Check both services in parallel
            var ratesTask = CurrencyApi.GetAllRatesAsync();
            var detectTask = CurrencyApi.DetectClientAsync();

            try { _ratesInfo = await ratesTask; } catch { _ratesInfo = null; }
            try { _detectedInfo = await detectTask; } catch { _detectedInfo = null; }

            _frankfurterStatus.IsOnline = _ratesInfo != null && _ratesInfo.Rates.Count > 0;
            _ipWhoIsStatus.IsOnline = _detectedInfo != null && !string.IsNullOrEmpty(_detectedInfo.CountryCode);
        }
        catch (Exception ex)
        {
            _statusMessage = $"Error checking services: {ex.Message}";
            _statusAlertClass = "alert-warning";
            _statusIcon = "bi-exclamation-triangle";
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task TestIpWhoIs()
    {
        _isTestingIp = true;
        _statusMessage = string.Empty;
        StateHasChanged();

        try
        {
            _detectedInfo = await CurrencyApi.DetectClientAsync();
            if (_detectedInfo != null && !string.IsNullOrEmpty(_detectedInfo.CountryCode))
            {
                _ipWhoIsStatus.IsOnline = true;
                _statusMessage = $"IpWhoIs is online — detected {_detectedInfo.CountryName} ({_detectedInfo.DetectedCurrency})";
                _statusAlertClass = "alert-success";
                _statusIcon = "bi-check-circle";
            }
            else
            {
                _ipWhoIsStatus.IsOnline = false;
                _statusMessage = "IpWhoIs returned no data. The service may be temporarily unavailable.";
                _statusAlertClass = "alert-warning";
                _statusIcon = "bi-exclamation-triangle";
            }
        }
        catch (Exception ex)
        {
            _ipWhoIsStatus.IsOnline = false;
            _statusMessage = $"IpWhoIs connection failed: {ex.Message}";
            _statusAlertClass = "alert-danger";
            _statusIcon = "bi-x-circle";
        }
        finally
        {
            _isTestingIp = false;
            StateHasChanged();
        }
    }

    private async Task TestFrankfurter()
    {
        _isTestingFrankfurter = true;
        _statusMessage = string.Empty;
        StateHasChanged();

        try
        {
            _ratesInfo = await CurrencyApi.GetAllRatesAsync();
            if (_ratesInfo != null && _ratesInfo.Rates.Count > 0)
            {
                _frankfurterStatus.IsOnline = true;
                _statusMessage = $"Frankfurter is online — {_ratesInfo.Rates.Count} exchange rates loaded (base: {_ratesInfo.BaseCurrency})";
                _statusAlertClass = "alert-success";
                _statusIcon = "bi-check-circle";
            }
            else
            {
                _frankfurterStatus.IsOnline = false;
                _statusMessage = "Frankfurter returned no rates. The service may be temporarily unavailable.";
                _statusAlertClass = "alert-warning";
                _statusIcon = "bi-exclamation-triangle";
            }
        }
        catch (Exception ex)
        {
            _frankfurterStatus.IsOnline = false;
            _statusMessage = $"Frankfurter connection failed: {ex.Message}";
            _statusAlertClass = "alert-danger";
            _statusIcon = "bi-x-circle";
        }
        finally
        {
            _isTestingFrankfurter = false;
            StateHasChanged();
        }
    }

    private class ApiStatus
    {
        public bool IsOnline { get; set; }
    }
}