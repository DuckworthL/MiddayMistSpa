    {
        _autoBackupSettings.Time = e.Value?.ToString() ?? "02:00";
    }

    private void RefreshBackups()
    {
        // TODO: Refresh from API
    }

    private void DownloadBackup(BackupModel backup)
    {
        // TODO: Trigger download
    }

    private void RestoreBackup(BackupModel backup)
    {
        _selectedBackup = backup;
        _confirmRestore = false;
        _showRestoreModal = true;
    }

    private void ConfirmRestore()
    {
        // TODO: Perform restore
        _showRestoreModal = false;
    }

    private void DeleteBackup(BackupModel backup)
    {
        _backups.Remove(backup);
    }

    private class AutoBackupSettings
    {
