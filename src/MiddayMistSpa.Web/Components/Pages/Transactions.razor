    {
        "Cash" => "bg-success",
        "Card" => "bg-primary",
        _ => "bg-secondary"
    };

    private string GetPaymentMethodIcon(string method) => method switch
    {
        "Cash" => "bi-cash",
        "Card" => "bi-credit-card",
        _ => "bi-wallet2"
    };

    private IEnumerable<(string Name, string? TherapistName, int Quantity, decimal UnitPrice, decimal TotalPrice)>
    GetTransactionItems(TransactionResponse txn)
    {
        if (txn.ServiceItems != null)
        {
            foreach (var s in txn.ServiceItems)
                yield return (s.ServiceName, s.TherapistName, s.Quantity, s.UnitPrice, s.TotalPrice);
        }
        if (txn.ProductItems != null)
        {
            foreach (var p in txn.ProductItems)
                yield return (p.ProductName, null, p.Quantity, p.UnitPrice, p.TotalPrice);
        }
    }

    private void ShowAlert(string message, Alert.AlertType type)
    {
        _alertMessage = message;
        _alertType = type;
    }
