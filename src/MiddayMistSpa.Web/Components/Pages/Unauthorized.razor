@page "/unauthorized"
@layout EmptyLayout

<PageTitle>Unauthorized - MiddayMist Spa</PageTitle>

<div class="unauthorized-page">
    <div class="unauthorized-card">
        <div class="icon-container">
            <i class="bi bi-shield-x"></i>
        </div>
        <h1>Access Denied</h1>
        <p class="text-secondary">You don't have permission to access this page.</p>
        <p class="text-muted small">Please contact your administrator if you believe this is an error.</p>
        <div class="d-flex gap-2 justify-content-center mt-4">
            <a href="/" class="btn btn-primary">
                <i class="bi bi-house me-2"></i>Go to Dashboard
            </a>
            <a href="/login" class="btn btn-outline-secondary">
                <i class="bi bi-box-arrow-in-right me-2"></i>Sign in as different user
            </a>
        </div>
    </div>
</div>

<style>
    .unauthorized-page {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #F8FAF8 0%, #E8EFE8 100%);
        padding: 2rem;
    }

    .unauthorized-card {
        text-align: center;
        background: #FFFFFF;
        border: 1px solid #E5E7EB;
        border-radius: 1rem;
        padding: 3rem;
        max-width: 500px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.06);
    }

    .icon-container {
        width: 100px;
        height: 100px;
        background: linear-gradient(135deg, #EF4444 0%, #DC2626 100%);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.5rem;
    }

    .icon-container i {
        font-size: 3rem;
        color: white;
    }

    h1 {
        color: #2C2C2C;
        font-weight: 700;
        margin-bottom: 0.5rem;
    }
</style>