@page "/"
@inject IDashboardService DashboardService
@inject IAppointmentApiService AppointmentService
@inject IAuthStateService AuthService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Dashboard - MiddayMist Spa</PageTitle>

@if (!_isAuthChecked)
{
    <LoadingSpinner Message="Checking authentication..." />
}
else
{
    <div class="container-fluid fade-in">
        @* Page Header *@
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1 class="h3 mb-1" style="color: #2C2C2C;">Dashboard</h1>
                <p class="mb-0" style="color: #6B7280;">Welcome back! Here's what's happening today.</p>
            </div>
            <div>
                <a href="/appointments/new" class="btn btn-primary">
                    <i class="bi bi-plus-lg me-1"></i> New Appointment
                </a>
            </div>
        </div>

        @if (_isLoading)
        {
            <LoadingSpinner Message="Loading dashboard..." />
        }
        else
        {
            @* Stats Cards *@
            <div class="row g-4 mb-4">
                <div class="col-12 col-sm-6 col-xl-3">
                    <StatCard Title="Today's Revenue" Value="@($"₱{_todayRevenue:N0}")" Icon="bi-currency-dollar"
                              Color="StatCard.CardColor.Success" />
                </div>
                <div class="col-12 col-sm-6 col-xl-3">
                    <StatCard Title="Appointments Today" Value="@_todayAppointments.ToString()"
                              SubValue="@($"{_completedAppointments} completed")" Icon="bi-calendar-check"
                              Color="StatCard.CardColor.Primary" />
                </div>
                <div class="col-12 col-sm-6 col-xl-3">
                    <StatCard Title="New Customers" Value="@_newCustomers.ToString()" Icon="bi-people"
                              Color="StatCard.CardColor.Info" />
                </div>
                <div class="col-12 col-sm-6 col-xl-3">
                    <StatCard Title="Low Stock Items" Value="@_lowStockItems.ToString()" Icon="bi-box-seam"
                              Color="@(_lowStockItems > 0 ? StatCard.CardColor.Warning : StatCard.CardColor.Success)" />
                </div>
            </div>

            <div class="row g-4">
                @* Upcoming Appointments *@
                <div class="col-12 col-lg-8">
                    <div class="card h-100">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <h5 class="mb-0" style="color: #2C2C2C;">Today's Appointments</h5>
                            <a href="/appointments" class="btn btn-sm btn-outline-primary">View All</a>
                        </div>
                        <div class="card-body p-0">
                            @if (_upcomingAppointments.Any())
                            {
                                <div class="table-responsive">
                                    <table class="table table-hover mb-0">
                                        <thead>
                                            <tr>
                                                <th>Time</th>
                                                <th>Customer</th>
                                                <th>Service</th>
                                                <th>Therapist</th>
                                                <th>Status</th>
                                                <th></th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var appt in _upcomingAppointments.Take(8))
                                            {
                                                <tr>
                                                    <td>
                                                        <span class="fw-medium">@appt.StartTime.ToString("hh\\:mm")</span>
                                                        <span class="small" style="color: #6B7280;">-
                                                            @appt.EndTime.ToString("hh\\:mm")</span>
                                                        </td>
                                                        <td>@appt.CustomerName</td>
                                                        <td>@appt.ServiceName</td>
                                                        <td>@(appt.TherapistName ?? "TBA")</td>
                                                        <td>
                                                            <StatusBadge Status="@appt.Status" />
                                                        </td>
                                                        <td>
                                                            <a href="/appointments/@appt.AppointmentId" class="btn btn-sm btn-link">
                                                                <i class="bi bi-eye"></i>
                                                            </a>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                            else
                                {
                                    <div class="text-center py-5">
                                        <i class="bi bi-calendar-x display-4 text-muted"></i>
                                        <p class="text-muted mt-2">No appointments scheduled for today</p>
                                        <a href="/appointments/new" class="btn btn-primary btn-sm">
                                            <i class="bi bi-plus me-1"></i> Schedule Appointment
                                        </a>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    @* Quick Actions & Stats *@
                    <div class="col-12 col-lg-4">
                        @* Quick Actions *@
                        <div class="card mb-4">
                            <div class="card-header">
                                <h5 class="mb-0" style="color: #2C2C2C;">Quick Actions</h5>
                            </div>
                            <div class="card-body">
                                <div class="d-grid gap-2">
                                    <a href="/customers" class="btn btn-outline-primary text-start">
                                        <i class="bi bi-person-plus me-2"></i> Add Customer
                                    </a>
                                    <a href="/transactions" class="btn btn-outline-primary text-start">
                                        <i class="bi bi-receipt me-2"></i> New Transaction
                                    </a>
                                    <a href="/inventory" class="btn btn-outline-primary text-start">
                                        <i class="bi bi-box-seam me-2"></i> Check Inventory
                                    </a>
                                </div>
                            </div>
                        </div>

                        @* Top Services *@
                        <div class="card">
                            <div class="card-header">
                                <h5 class="mb-0" style="color: #2C2C2C;">Top Services (This Month)</h5>
                            </div>
                            <div class="card-body">
                                @if (_topServices.Any())
                                {
                                    @foreach (var service in _topServices.Take(5))
                                    {
                                        <div class="d-flex justify-content-between align-items-center mb-3">
                                            <div>
                                                <div class="fw-medium" style="color: #2C2C2C;">@service.ServiceName</div>
                                                <small style="color: #6B7280;">@service.BookingCount bookings</small>
                                            </div>
                                            <span class="badge bg-success">₱@service.TotalRevenue.ToString("N0")</span>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <p class="text-center mb-0" style="color: #6B7280;">No data available</p>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                @* Revenue Chart Area *@
                <div class="row mt-4">
                    <div class="col-12">
                        <div class="card border-0 shadow-sm">
                            <div class="card-header bg-white border-0 d-flex justify-content-between align-items-center">
                                <h5 class="mb-0">Revenue Overview</h5>
                                <div class="btn-group btn-group-sm">
                                    <button class="btn @(_revenueView == "week" ? "btn-primary" : "btn-outline-secondary")"
                                            @onclick="@(() => SetRevenueView("week"))">Week</button>
                                    <button class="btn @(_revenueView == "month" ? "btn-primary" : "btn-outline-secondary")"
                                            @onclick="@(() => SetRevenueView("month"))">Month</button>
                                </div>
                            </div>
                            <div class="card-body">
                                @if (_revenueData.Any())
                                {
                                    <div style="height: 280px; position: relative;">
                                        <canvas id="revenueChart"></canvas>
                                    </div>
                                }
                                else
                                {
                                    <div class="text-center py-5 text-muted">
                                        <i class="bi bi-bar-chart display-4"></i>
                                        <p class="mt-2">No revenue data for this period</p>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

@code {
    private bool _isLoading = true;
    private decimal _todayRevenue;
    private int _todayAppointments;
    private int _completedAppointments;
    private int _newCustomers;
    private int _lowStockItems;
    private List<AppointmentSummary> _upcomingAppointments = new();
    private List<TopService> _topServices = new();
    private List<DailyRevenue> _revenueData = new();
    private string _revenueView = "week"; // "week" or "month"

    protected override void OnInitialized()
    {
        // Data will be loaded after auth check in OnAfterRenderAsync
    }

    private async Task LoadDashboardData()
    {
        _isLoading = true;

        try
        {
            // Load dashboard summary
            var summary = await DashboardService.GetDashboardSummaryAsync();
            if (summary != null)
            {
                _todayRevenue = summary.Kpis.TotalRevenue;
                _todayAppointments = summary.Kpis.TotalAppointments;
                _completedAppointments = summary.Appointments.Completed;
                _newCustomers = summary.Kpis.NewCustomers;
                _lowStockItems = summary.Inventory.LowStockItems;
                _topServices = summary.TopServices;

                // Use DailyTrend from dashboard for initial chart data
                _revenueData = summary.Revenue.DailyTrend ?? new();
            }
            else
            {
                // Fallback: load today's appointments directly
                var todayAppts = await AppointmentService.GetAppointmentsAsync(date: DateTime.Today);
                _upcomingAppointments = todayAppts.Items.Select(a => new AppointmentSummary
                {
                    AppointmentId = a.AppointmentId,
                    CustomerName = a.CustomerName,
                    ServiceName = a.ServiceName,
                    TherapistName = a.TherapistName ?? "",
                    AppointmentDate = a.AppointmentDate,
                    StartTime = a.StartTime,
                    EndTime = a.EndTime,
                    Status = a.Status
                }).ToList();
                _todayAppointments = todayAppts.TotalCount;
            }

            // Load upcoming appointments (from today's)
            if (!_upcomingAppointments.Any())
            {
                var todayAppts2 = await AppointmentService.GetAppointmentsAsync(date: DateTime.Today);
                _upcomingAppointments = todayAppts2.Items.Select(a => new AppointmentSummary
                {
                    AppointmentId = a.AppointmentId,
                    CustomerName = a.CustomerName,
                    ServiceName = a.ServiceName,
                    TherapistName = a.TherapistName ?? "",
                    AppointmentDate = a.AppointmentDate,
                    StartTime = a.StartTime,
                    EndTime = a.EndTime,
                    Status = a.Status
                }).ToList();
            }

            // Load revenue data for the selected period
            await LoadRevenueData();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading dashboard: {ex.Message}");
        }

        _isLoading = false;
    }

    private async Task LoadRevenueData()
    {
        try
        {
            var endDate = DateTime.Today;
            var startDate = _revenueView == "week" ? endDate.AddDays(-6) : endDate.AddDays(-29);
            _revenueData = await DashboardService.GetRevenueAsync(startDate, endDate);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading revenue: {ex.Message}");
            _revenueData = new();
        }
    }

    private async Task SetRevenueView(string view)
    {
        if (_revenueView == view) return;
        _revenueView = view;
        await LoadRevenueData();
        StateHasChanged();
        await RenderRevenueChart();
    }

    private async Task RenderRevenueChart()
    {
        if (!_revenueData.Any()) return;

        try
        {
            var labels = _revenueData.Select(d =>
                _revenueView == "week" ? d.Date.ToString("ddd") : d.Date.ToString("MMM dd")).ToArray();
            var data = _revenueData.Select(d => (double)d.Revenue).ToArray();

            var datasets = new[]
            {
                new
                {
                    label = "Revenue (₱)",
                    data = data,
                    borderColor = "rgba(99, 102, 241, 1)",
                    backgroundColor = "rgba(99, 102, 241, 0.15)",
                    fill = true,
                    tension = 0.4,
                    pointRadius = 4,
                    pointBackgroundColor = "rgba(99, 102, 241, 1)",
                    pointBorderColor = "#fff",
                    pointBorderWidth = 2,
                    borderWidth = 2
                }
            };

            var options = new
            {
                scales = new
                {
                    y = new
                    {
                        beginAtZero = true,
                        ticks = new { callback_format = "peso" }
                    }
                },
                plugins = new
                {
                    legend = new { display = false },
                    tooltip = new
                    {
                        callbacks = new { label_format = "peso" }
                    }
                },
                interaction = new { intersect = false, mode = "index" }
            };

            await JS.InvokeVoidAsync("renderChart", "revenueChart", "line", labels, datasets, options);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error rendering chart: {ex.Message}");
        }
    }

    private bool _isAuthChecked = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Try to restore session
            await AuthService.TryRestoreSessionAsync();

            if (!AuthService.IsAuthenticated)
            {
                Navigation.NavigateTo("/login");
                return;
            }

            _isAuthChecked = true;

            // Now load data after auth is ready
            await LoadDashboardData();
            StateHasChanged();

            // Render chart after data loaded and DOM updated
            await Task.Delay(100);
            await RenderRevenueChart();
        }
    }
}