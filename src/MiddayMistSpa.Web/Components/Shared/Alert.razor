@* Alert/Notification Component with auto-dismiss *@
@if (!string.IsNullOrEmpty(Message))
{
    <div class="@AlertFullClass" role="alert" style="opacity: 1 !important;">
        @if (!string.IsNullOrEmpty(Icon))
        {
            <i class="bi @Icon me-2"></i>
        }
        @Message
        @if (Dismissible)
        {
            <button type="button" class="btn-close" @onclick="Dismiss" aria-label="Close"></button>
        }
    </div>
}

@code {
    [Parameter] public string Message { get; set; } = string.Empty;
    [Parameter] public AlertType Type { get; set; } = AlertType.Info;
    [Parameter] public bool Dismissible { get; set; } = true;
    [Parameter] public bool AutoDismiss { get; set; } = true;
    [Parameter] public int AutoDismissMs { get; set; } = 3000;
    [Parameter] public EventCallback OnDismiss { get; set; }

    private string? _lastMessage;
    private CancellationTokenSource? _autoDismissCts;

    private string AlertClass => Type switch
    {
        AlertType.Success => "alert-success",
        AlertType.Warning => "alert-warning",
        AlertType.Error => "alert-danger",
        _ => "alert-info"
    };

    private string AlertFullClass => $"alert {AlertClass} {(Dismissible ? "alert-dismissible fade show" : "")} alert-opaque";

    private string Icon => Type switch
    {
        AlertType.Success => "bi-check-circle-fill",
        AlertType.Warning => "bi-exclamation-triangle-fill",
        AlertType.Error => "bi-x-circle-fill",
        _ => "bi-info-circle-fill"
    };

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrEmpty(Message) && Message != _lastMessage && AutoDismiss)
        {
            _lastMessage = Message;
            _ = StartAutoDismissAsync();
        }
    }

    private async Task StartAutoDismissAsync()
    {
        _autoDismissCts?.Cancel();
        _autoDismissCts = new CancellationTokenSource();
        var token = _autoDismissCts.Token;

        try
        {
            await Task.Delay(AutoDismissMs, token);
            if (!token.IsCancellationRequested)
            {
                await Dismiss();
                StateHasChanged();
            }
        }
        catch (TaskCanceledException) { }
    }

    private async Task Dismiss()
    {
        _autoDismissCts?.Cancel();
        Message = string.Empty;
        _lastMessage = null;
        await OnDismiss.InvokeAsync();
    }

    public enum AlertType
    {
        Info,
        Success,
        Warning,
        Error
    }
}